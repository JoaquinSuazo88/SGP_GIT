                     If Not (RSAux1.EOF And RSAux1.BOF) Then RSAux1.MoveFirst: MaxFil = RSAux1.Fields(0)
                     RSAux1.Close
                     Set RSAux1 = Nothing
                 
                 End If
                 j = 1 + RS1!mid_numlin
                 LineaAnte = j
               
                 If j > filmay Then filmay = j
                 If RS1!mid_estser <> auxser Then
                    
                    '------- Revisar si existe una estructura fija
                    essnom = False: cLin = ""
                    For p = 1 To j
                        
                        If .TableCell(tcText, p, 1) = Trim(RS1!ess_nombre) Then essnom = True: cLin = "": Exit For
                    
                    Next p
                    If essnom = False Then .TableCell(tcText, j, 2) = IIf(opnomest = True And tipoceco = "1", IIf(IIf(IsNull(RS1!mid_desest) = True, "", RS1!mid_desest) <> "", RS1!mid_desest, RS1!ess_nombre), RS1!ess_nombre): cLin = .TableCell(tcText, j, 2)
                    '------- Fin revisar si existe una estructura fija
                    auxser = RS1!mid_estser
                 
                 End If
                 
                 For X = 2 To icol
                     
                     If VecDia(X - 1) = fg_Dia(RS1!min_fecmin) Then
                        
                        .TableCell(tcText, j, X + 1) = IIf(opnomrec = True, IIf(Not opparentesis, ExtraeParentesis(IIf(IsNull(RS1!rec_nomfan) = True, "", RS1!rec_nomfan)), IIf(IsNull(RS1!rec_nomfan) = True, "", RS1!rec_nomfan)) & " " & IIf(Raciones = 1, "( " & RS1!mid_numrac & " raciones)", "") & " " & IIf(Costo = 1, " - Costo uni. $ " & Format((RS1!mid_cosrec), fg_Pict(6, 2)), ""), IIf(Not opparentesis, ExtraeParentesis(IIf(IsNull(RS1!rec_nombre) = True, "", RS1!rec_nombre)), IIf(IsNull(RS1!rec_nombre) = True, "", RS1!rec_nombre)) & " " & IIf(Raciones = 1, "( " & RS1!mid_numrac & " raciones)", "") & " " & IIf(Costo = 1, " - Costo uni. $ " & Format((RS1!mid_cosrec), fg_Pict(6, 2)), ""))
                        ColumnaAnt = DatePart("w", fg_Ctod1(RS1!min_fecmin), 2)
                     
                     End If
                 
                 Next X
                    
                    
                 '** INICIO  - OBTIENE LA FILA MAXIMA DE LA TABLA
                    'Lo siguiente averigua si la existen sabados o domingos para agregar o obviar estas columnas
                     .TableCell(tcText, (MaxFil / 2) + 1, 1) = Trim(RS1!ser_nombre) 'G_Proc.fg_TraerNombre("a_servicio", "ser_codigo", RS1!min_codser, "ser_nombre")
                     .TableCell(tcVertical, (MaxFil / 2) + 1, 1) = True
                 '** FIN - OBTIENE LA FILA MAXIMA DE LA TABLA
                 NumSemanaAnt = DatePart("ww", fg_Ctod1(RS1!min_fecmin), 2) 'SemanaDeAńo(RS1!min_fecmin)
                
                 RS1.MoveNext
              
              Loop
              j = 2
              
              For j = 1 To filmay
                 
                 cLin = ""
                  
                  For X = 1 To icol + 1
                     
                     cLin = cLin & .TableCell(tcText, j, X) & "|"
                  
                  Next X
                  
                  Print #1, cLin
              
              Next j
              Print #1, Chr(13): Print #1, Chr(13): cLin = ""
              .TableCell(tcRows) = filmay + 1: .TableBorder = tbBoxColumns: .EndTable
           
           End If
           RS1.Close: Set RS1 = Nothing
           .text = Chr(13): .text = Chr(13)
           fecini1 = xxx
       
       End If
    
    Next xxx
    
    ExportHeaderFooter Preview.VSPrinter
    Close #1
    .EndDoc
End With
