Public Function I_AportePlanDetallado(cForm As Form, subseg As Long, codReg As Long, codzon As Long, FecIni As Long, FecFin As Long, TipMin As String, opnomrec As Boolean, spid As Long, Indppr As String, opSemCerrada As Boolean, opparentesis As Boolean)

Dim i As Long, j As Long, X As Long, Y As Long, z As Long, p As Long, ii As Long, NotA As Long, AsiA As Long, CumA As Long, CerA As Long, codser As Long, AuxFec As Long, icol As Long
Dim auxrec As Long, codnut As Long, inut As Long, ind_ini As Long, ind_par As Long, codapo As Long, indfin As Long
Dim canapo As Double
Dim nomser As String, nomtip As String, cLin As String, codpro As String
Dim VecDie() As Long
Dim vecrec() As Double
Dim VecDia() As Double

On Local Error GoTo Error_AporDetalle

fg_carga ""
MsgTitulo = "Informe Aporte en Detalle"
Preview.Refresh
With Preview.VSPrinter
    .Styles.Apply "Default"
    .ExportFormat = vpxRTF
    .ExportFile = fg_ArchivoRtf 'App.Path & "\Reporte.rtf"
    .Preview = True
    .PreviewPage = 1
    .Orientation = orPortrait
    .MarginLeft = 500
    .StartDoc
    .PageBorder = 0
    .HdrFontName = "Arial"
    .HdrFontSize = 8
    .HdrFontBold = True
    .Header = "||"
    .Footer = "" & fg_ponepiepagina & "||Página : %d"
    .FontSize = 8
    ExportHeaderFooter Preview.VSPrinter
    vg_Archxls = fg_ArchivoTxt
    Open vg_Archxls For Output As #1
    icol = 6
    ReDim Preserve VecDie(0)
    ReDim Preserve vecrec(0)
    ReDim Preserve VecDia(0)
    If cForm.Option1(4).Value = True Then icol = 2
    If cForm.Option1(5).Value = True Then icol = 2
    If cForm.Option1(6).Value = True Then icol = 2
    If cForm.Option1(12).Value = True Then icol = 2
   
    inut = 0
    For i = 1 To cForm.vaSpread2.MaxRows
        cForm.vaSpread2.Row = i
        cForm.vaSpread2.Col = 1
        If cForm.vaSpread2.text = "1" Then
           icol = icol + 1: inut = inut + 1
           ReDim Preserve VecDie(inut)
           cForm.vaSpread2.Col = 2
           VecDie(inut) = cForm.vaSpread2.text
        End If
    Next i
  
    ReDim Preserve vecrec(inut)
    ReDim Preserve VecDia(inut)
    For i = 1 To cForm.vaSpread1.MaxRows
        cForm.vaSpread1.Row = i
        cForm.vaSpread1.Col = 1
        If cForm.vaSpread1.text = "1" Then
           cForm.vaSpread1.Col = 2
           codser = Val(cForm.vaSpread1.text)
           cForm.vaSpread1.Col = 3
           nomser = cForm.vaSpread1.text
           If AuxFec > 0 Then .NewPage
           .StartTable
           .TableCell(tcCols) = 1: .TableCell(tcRows) = 1
           .TableCell(tcColWidth, , 1) = 10500: .TableCell(tcAlign, , 1) = taCenterMiddle
           .TableCell(tcFontSize, 1) = 14: .TableCell(tcFontBold, 1) = True
           nomtip = IIf(TipMin = 1, "Teórico", "Real")
           .TableCell(tcText, 1, 1) = "Aporte Nutricional Detallado (" & nomtip & ")  " & Mid(FecIni, 5, 2) & "/" & Mid(FecIni, 1, 4) & IIf(Indppr = "1", " Real", "  Propuesta")
            '--- Impresión titulo informe ---
           Print #1, .TableCell(tcText, 1, 1)
            '-----  Se definen los parametros Informe  ----
           .TableBorder = tbNone
           .EndTable
           .text = Chr(13): .text = Chr(13): .text = Chr(13)
           '-------> Mover aportes nutriconales
           
           If RS1.State = 1 Then RS1.Close
           RS1.CursorLocation = adUseClient
           vg_db.CursorLocation = adUseClient
           Set RS1 = vg_db.Execute("sgpadm_s_aporteplanifminuta " & subseg & ", " & codReg & ", " & codser & ", " & FecIni & ", " & FecFin & ", " & codzon & ", '" & vg_NUsr & "','" & Indppr & "'")
           
           If RS1.EOF Then RS1.Close: Set RS1 = Nothing: Close #1: Exit Function
           Preview.vaSpread1.MaxRows = 0
           Preview.vaSpread1.maxcols = 3
           Do While Not RS1.EOF
              Preview.vaSpread1.MaxRows = Preview.vaSpread1.MaxRows + 1
              Preview.vaSpread1.Row = Preview.vaSpread1.MaxRows
              Preview.vaSpread1.Col = 1: Preview.vaSpread1.text = RS1!pnu_codpro
              Preview.vaSpread1.Col = 2: Preview.vaSpread1.text = RS1!pnu_codapo
              Preview.vaSpread1.Col = 3: Preview.vaSpread1.text = RS1!pnu_canapo
              RS1.MoveNext
           Loop
           RS1.Close: Set RS1 = Nothing

           If RS1.State = 1 Then RS1.Close
           RS1.CursorLocation = adUseClient
           vg_db.CursorLocation = adUseClient
           Set RS1 = vg_db.Execute("sgpadm_s_aporteminutasdet " & subseg & ", " & codReg & ", " & codser & ", " & codzon & ", " & FecIni & ", " & FecFin & ", '" & TipMin & "'," & Indppr & "")
           If RS1.EOF Then RS1.Close: Set RS1 = Nothing: Close #1: Exit For
           .StartTable
           .TableCell(tcCols) = 2: .TableCell(tcRows) = 5
           .TableCell(tcColWidth, , 1) = 1000: .TableCell(tcAlign, , 1) = taLeftTop
           .TableCell(tcColWidth, , 2) = 9000: .TableCell(tcAlign, , 1) = taLeftTop
           .TableCell(tcFontBold, 1, 1) = True: .TableCell(tcText, 1, 1) = "Casino"
           .TableCell(tcFontBold, 2, 1) = True: .TableCell(tcText, 2, 1) = "Regimen"
           .TableCell(tcFontBold, 3, 1) = True: .TableCell(tcText, 3, 1) = "Zona"
           .TableCell(tcFontBold, 4, 1) = True: .TableCell(tcText, 4, 1) = "Servicio"
           '.TableCell(tcFontBold, 5, 1) = True: .TableCell(tcText, 5, 1) = "Cant. Servida Ma."
           '---  Impresion valores selección  ---------
           Print #1, .TableCell(tcText, 1, 1)
           
           If RS2.State = 1 Then RS2.Close
           RS2.CursorLocation = adUseClient
           vg_db.CursorLocation = adUseClient
           Set RS2 = vg_db.Execute("sgpadm_s_subsegmento 1, " & subseg & ", '', ''")
           If Not RS2.EOF Then .TableCell(tcFontBold, 1, 2) = True: .TableCell(tcText, 1, 2) = RS2!sub_nombre
           RS2.Close: Set RS2 = Nothing
           
           If RS2.State = 1 Then RS2.Close
           RS2.CursorLocation = adUseClient
           vg_db.CursorLocation = adUseClient
           Set RS2 = vg_db.Execute("sgpadm_s_regimen 1, " & codReg & ", ''")
           If Not RS2.EOF Then .TableCell(tcFontBold, 2, 2) = True: .TableCell(tcText, 2, 2) = RS2!reg_nombre
           RS2.Close: Set RS2 = Nothing
           
           If RS2.State = 1 Then RS2.Close
           RS2.CursorLocation = adUseClient
           vg_db.CursorLocation = adUseClient
           Set RS2 = vg_db.Execute("sgpadm_s_zona 1, " & codzon & ", ''")
           If Not RS2.EOF Then .TableCell(tcFontBold, 3, 2) = True: .TableCell(tcText, 3, 2) = RS2!Zon_nombre
           RS2.Close: Set RS2 = Nothing
           
           .TableCell(tcFontBold, 4, 2) = True: .TableCell(tcText, 4, 2) = nomser
           Print #1, .TableCell(tcText, 1, 1) & "|" & .TableCell(tcText, 1, 2)
           Print #1, .TableCell(tcText, 2, 1) & "|" & .TableCell(tcText, 2, 2)
           Print #1, .TableCell(tcText, 3, 1) & "|" & .TableCell(tcText, 3, 2)
           Print #1, .TableCell(tcText, 4, 1) & "|" & .TableCell(tcText, 4, 2)  ' Falta que traiga el servicio
           IniIncDia = 1
