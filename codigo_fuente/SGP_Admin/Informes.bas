                OchPor = 0
                TotFam = 0
                wvarAgrupaFamilia = Trim(RS1!fampro)
            End If
            OchPor = OchPor + RS1!PesoFamProd
            
            TotFam = IIf(IsNull(RS1!TotFam), 0, RS1!TotFam)
            
            Dim wvarArr8020() As String
            wvarGroupFam = Trim(RS1!fampro)
            wvarStrFamPorc = wvarGroupFam
            wvarArr8020 = Split(wvarStrFamPorc, "|")
            wvarCant8020 = wvarArr8020(0)
            
            wvarAgrupaFamilia = Trim(RS1!fampro)
            Dim ArregloConsFact() As String
            ArregloConsFact = Split(Trim(RS1!fampro), "\")
            wvarFamPrimerNivel = ArregloConsFact(1)
            
            If OchPor <= 80 Then
                .TableCell(tcText, i, 1) = M_SsllIPA.AsignaMesStr(periodo)
                .TableCell(tcText, i, 2) = Trim(RS1!nomsac)
                
                If RS1!unimed = "" Then
                    wvarunidad = 0
                Else
                    wvarunidad = RS1!unimed
                End If
                
                .TableCell(tcText, i, 3) = Trim(RS1!unisac)
                
                .TableCell(tcText, i, 4) = Trim(wvarFamPrimerNivel)
                
                wvarPrecioBase = Val(CDbl(RS1!precos))
                .TableCell(tcText, i, 5) = Format(Val(CDbl(RS1!precos)), fg_Pict(9, 2))
                
                wvarCantMer = Val(CDbl(RS1!canmer))
                .TableCell(tcText, i, 6) = Format(Val(CDbl(RS1!canmer)), fg_Pict(9, 2))
                
                wvarTotalFactura = wvarPrecioBase * wvarCantMer
                .TableCell(tcText, i, 7) = Format(Val(CDbl(wvarTotalFactura)), fg_Pict(9, 2))
    
                .TableCell(tcText, i, 8) = Format(RS1!PesoFamProd, fg_Pict(3, 2))
    
                SumOch = SumOch + wvarTotalFactura
                
                Print #1, .TableCell(tcText, i, 1) & "|" & .TableCell(tcText, i, 2) & "|" & .TableCell(tcText, i, 3) & _
                    "|" & .TableCell(tcText, i, 4) & "|" & .TableCell(tcText, i, 5) & "|" & .TableCell(tcText, i, 6) & "|" & _
                    "|" & .TableCell(tcText, i, 7) & "|" & .TableCell(tcText, i, 8) & "|"
                i = i + 1
            End If
            RS1.MoveNext
        Loop
            If (Trim(wvarAgrupaFamilia) <> "") Then
                
                .TableCell(tcText, i, 2) = "SUBTOTAL " & wvarFamPrimerNivel & " 80 / 20"
                .TableCell(tcText, i, 7) = Format(Val(SumOch), fg_Pict(9, 2))
                .TableCell(tcFontBold, i, 2) = True
                .TableCell(tcFontBold, i, 7) = True
                .TableCell(tcBackColor, i) = &HCCFFFF
                
                TotGrl = TotGrl + SumOch
                i = i + 1
                
                .TableCell(tcText, i, 2) = "SUBTOTAL " & wvarFamPrimerNivel
                .TableCell(tcText, i, 7) = Format(Val(TotFam), fg_Pict(9, 2))
                .TableCell(tcFontBold, i, 2) = True
                .TableCell(tcFontBold, i, 7) = True
                .TableCell(tcBackColor, i) = &HCCFFFF
                
                i = i + 2
                SumOch = 0
                OchPor = 0
                TotFam = 0
            End If
    
    Else
        i = i + 1
    End If
    RS1.Close: Set RS1 = Nothing
    
'---total-productos------------------------------------------------------------------------------------------
    i = i + 2
    .TableCell(tcRows) = i
    .TableCell(tcText, i, 2) = UCase("Total Facturación")
    .TableCell(tcAlign, i, 7) = taRightTop
    .TableCell(tcText, i, 7) = Format(Val(CDbl(TotGrl)), fg_Pict(9, 2))
    .TableCell(tcFontBold, i, 2) = True: .TableCell(tcFontBold, i, 7) = True
    .TableCell(tcBackColor, i) = &HCCFFFF
    .TableCell(tcAlign, i, 5) = taRightTop
    
    Print #1, .TableCell(tcText, i, 1) & "|" & .TableCell(tcText, i, 2) & "|" & .TableCell(tcText, i, 3) & _
        "|" & .TableCell(tcText, i, 4) & "|" & .TableCell(tcText, i, 5) & "|" & .TableCell(tcText, i, 6) & "|" & _
        "|" & .TableCell(tcText, i, 7) & "|" & .TableCell(tcText, i, 8) & "|"
''------------------------------------------------------------------------------------------------------------

    .TableCell(tcRows) = i
    .PenColor = &HC0C0C0
    .TableBorder = tbAll
    .EndTable
    .EndDoc
    Close #1
End With
Preview.Show 1
fg_descarga
Exit Function
Error_ConsolFact:
    fg_descarga
    MsgBox Err.Number & " " & Err.Description, vbExclamation + vbOKOnly, MsgTitulo
    Close #1
    Exit Function
End Function

