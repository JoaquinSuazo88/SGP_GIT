                              cLin = cLin & .TableCell(tcText, 1, X) & vbTab
                           Else
                              .TableCell(tcColWidth, , X) = anccol: .TableCell(tcAlign, , X) = taCenterMiddle
                              Select Case X
                              Case 2
                                    If opSemCerrada = False Then
                                        .TableCell(tcText, 1, X) = "Lunes " & IIf(Idia > diafin, "", fg_pone_cero(Str(Idia), 2))
                                        If dianva Then .TableCell(tcBackColor, 1, X) = vbScrollBars
                                    Else
                                        .TableCell(tcText, 1, X) = "DIA " & fg_pone_cero(Str(IniIncDia), 2)
                                        If dianva Then .TableCell(tcBackColor, 1, X) = vbScrollBars
                                        IniIncDia = IniIncDia + 1
                                    End If
                              Case 3
                                If opSemCerrada = False Then
                                    .TableCell(tcText, 1, X) = "Martes " & IIf(Idia > diafin, "", fg_pone_cero(Str(Idia), 2))
                                    If dianva Then .TableCell(tcBackColor, 1, X) = vbScrollBars
                                Else
                                    .TableCell(tcText, 1, X) = "DIA " & fg_pone_cero(Str(IniIncDia), 2)
                                    If dianva Then .TableCell(tcBackColor, 1, X) = vbScrollBars
                                    IniIncDia = IniIncDia + 1
                                End If
                              Case 4
                                If opSemCerrada = False Then
                                    .TableCell(tcText, 1, X) = "Miércoles " & IIf(Idia > diafin, "", fg_pone_cero(Str(Idia), 2))
                                    If dianva Then .TableCell(tcBackColor, 1, X) = vbScrollBars
                                Else
                                    .TableCell(tcText, 1, X) = "DIA " & fg_pone_cero(Str(IniIncDia), 2)
                                    If dianva Then .TableCell(tcBackColor, 1, X) = vbScrollBars
                                    IniIncDia = IniIncDia + 1
                                End If
                              Case 5
                                If opSemCerrada = False Then
                                    .TableCell(tcText, 1, X) = "Jueves " & IIf(Idia > diafin, "", fg_pone_cero(Str(Idia), 2))
                                    If dianva Then .TableCell(tcBackColor, 1, X) = vbScrollBars
                                Else
                                    .TableCell(tcText, 1, X) = "DIA " & fg_pone_cero(Str(IniIncDia), 2)
                                    If dianva Then .TableCell(tcBackColor, 1, X) = vbScrollBars
                                    IniIncDia = IniIncDia + 1
                                End If
                              Case 6
                                If opSemCerrada = False Then
                                    .TableCell(tcText, 1, X) = "Viernes " & IIf(Idia > diafin, "", fg_pone_cero(Str(Idia), 2))
                                    If dianva Then .TableCell(tcBackColor, 1, X) = vbScrollBars
                                Else
                                    .TableCell(tcText, 1, X) = "DIA " & fg_pone_cero(Str(IniIncDia), 2)
                                    If dianva Then .TableCell(tcBackColor, 1, X) = vbScrollBars
                                    IniIncDia = IniIncDia + 1
                                End If
                              Case 7
                                If opSemCerrada = False Then
                                    .TableCell(tcText, 1, X) = "Sábado " & IIf(Idia > diafin, "", fg_pone_cero(Str(Idia), 2))
                                    If dianva Then .TableCell(tcBackColor, 1, X) = vbScrollBars
                                Else
                                    .TableCell(tcText, 1, X) = "DIA " & fg_pone_cero(Str(IniIncDia), 2)
                                    If dianva Then .TableCell(tcBackColor, 1, X) = vbScrollBars
                                    IniIncDia = IniIncDia + 1
                                End If
                              Case 8
                                If opSemCerrada = False Then
                                    .TableCell(tcText, 1, X) = "Domingo " & IIf(Idia > diafin, "", fg_pone_cero(Str(Idia), 2))
                                    If dianva Then .TableCell(tcBackColor, 1, X) = vbScrollBars
                                Else
                                    .TableCell(tcText, 1, X) = "DIA " & fg_pone_cero(Str(IniIncDia), 2)
                                    If dianva Then .TableCell(tcBackColor, 1, X) = vbScrollBars
                                    IniIncDia = IniIncDia + 1
                                End If
                              End Select
                              cLin = cLin & .TableCell(tcText, 1, X) & "|"
                              If Idia >= diafin Then Idia = 0: dianva = True
                              Idia = Idia + 1
                           End If
                       Next X
                       Print #1, cLin
                       .TableBorder = tbAll
                       .EndTable
                       .StartTable
                       .TableCell(tcCols) = icol + 1: .TableCell(tcRows) = 1000
                       .TableCell(tcAlign, 1, 1) = taCenterMiddle
                       .TableCell(tcColWidth, , 1) = 1400
                       For X = 1 To icol + 1
                           If X = 1 Then
                              .TableCell(tcFontName) = "Arial Narrow"
                              .TableCell(tcFontSize) = 8
                              .TableCell(tcFontBold, 1) = True
                              .TableCell(tcColWidth, , X) = 1500: .TableCell(tcAlign, , X) = taCenterMiddle
                              .TableCell(tcText, 1, X) = ""
                           Else
                              .TableCell(tcColWidth, , X) = anccol: .TableCell(tcAlign, , X) = taCenterMiddle
                           End If
                       Next X
                    End If
                    auxser = 0
                    AuxFec = DatePart("ww", fg_Ctod1(RestarFecha(RS1!min_fecmin, RestaDias)), 2)
                 End If
                 j = 1 + RS1!mid_numlin
                 If j > filmay Then filmay = j
                 If RS1!mid_estser <> auxser Then
                    '------- Revisar si existe una estructura fija
                    essnom = False: cLin = ""
                    For p = 1 To j
                        If .TableCell(tcText, p, 1) = RS1!ess_nombre Then essnom = True: cLin = "": Exit For
                    Next p
                    If essnom = False Then .TableCell(tcText, j, 1) = IIf(opnomest = True, IIf(IIf(IsNull(RS1!mid_desest) = True, "", RS1!mid_desest) <> "", RS1!mid_desest, RS1!ess_nombre), RS1!ess_nombre): cLin = .TableCell(tcText, j, 1)
                    '------- Fin revisar si existe una estructura fija
                    auxser = RS1!mid_estser
                 End If
                
                    
            'trabajando samuel
            For X = 1 To 7
               If VecDia(X) = fg_Dia(RestarFecha(RS1!min_fecmin, RestaDias)) Then
                   .TableCell(tcText, j, X + 1) = IIf(opnomrec = True, ExtraeParentesis(IIf(IsNull(RS1!rec_nomfan) = True, "", RS1!rec_nomfan)) & " " & IIf(Raciones = 1, "( " & RS1!mid_numrac & " raciones)", "") & " " & IIf(Costo = 1, " - Costo uni. $ " & Format((RS1!mid_cosrec), fg_Pict(6, 2)), ""), ExtraeParentesis(IIf(IsNull(RS1!rec_nombre) = True, "", RS1!rec_nombre)) & " " & IIf(Raciones = 1, "( " & RS1!mid_numrac & " raciones)", "") & " " & IIf(Costo = 1, " - Costo uni. $ " & Format((RS1!mid_cosrec), fg_Pict(6, 2)), ""))
                End If
            Next X
                
                 RS1.MoveNext
              Loop
              
              
              
              j = 2
              For j = 1 To filmay
                 cLin = ""
                  For X = 1 To icol + 1
                     cLin = cLin & .TableCell(tcText, j, X) & "|"
                  Next X
                  Print #1, cLin
              Next j
              Print #1, Chr(13): Print #1, Chr(13): cLin = ""
              .TableCell(tcRows) = filmay + 1: .TableBorder = tbBoxColumns: .EndTable
           End If
           RS1.Close: Set RS1 = Nothing
        End If
    Next i
    ExportHeaderFooter Preview.VSPrinter
    Close #1
    .EndDoc
End With
Preview.Show 1
Exit Function
Error_PlanMensual:
    fg_descarga
    MsgBox Err.Number & " " & Err.Description, vbExclamation + vbOKOnly, MsgTitulo
    Close #1
    Exit Function
End Function

