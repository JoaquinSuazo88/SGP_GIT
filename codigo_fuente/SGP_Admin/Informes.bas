                        .TableCell(tcText, fil, 5) = Format(canser, fg_Pict(6, vg_RDCa))
                        .TableCell(tcText, fil, 6) = Format(cannet, fg_Pict(6, vg_RDCa))
                        totcanpro = totcanpro + canpro
                        totcanser = totcanser + canser
                        totcannet = totcannet + cannet
                        totcannetapro = totcannetapro + cannetapro
                        Col = 6
                        
                        If RS2.State = 1 Then RS2.Close
                        RS2.CursorLocation = adUseClient
                        vg_db.CursorLocation = adUseClient
                        Set RS2 = vg_db.Execute("SELECT pnu_codpro, pnu_codapo, pnu_canapo FROM b_productonut With (NoLock) WHERE pnu_codpro='" & RS1!red_codpro & "'")
                        If Not RS2.EOF Then
                            
                            lc_codpro = RS2!pnu_codpro
                            Do While Not RS2.EOF
                               
                               cantidad = (((RS1!red_pctnut / 100) * (RS2!pnu_canapo * (RS1!red_canpro / RS1!rec_basrac))) / RS1!ing_facnut)
                               .TableCell(tcText, fil, VecCol(Val(RS2!pnu_codapo))) = Format(cantidad, fg_Pict(6, vg_DCa))
                               vector(Val(RS2!pnu_codapo)) = vector(Val(RS2!pnu_codapo)) + Format(cantidad, fg_Pict(6, vg_DCa))
                               Col = Col + 1
                               RS2.MoveNext
                            
                            Loop
                        Else
                            
                            vector(Col) = vector(Col) + Format(0, fg_Pict(6, vg_DCa))
                            Col = Col + 1
                        
                        End If
                        RS2.Close
                        Set RS2 = Nothing

                    RS1.MoveNext
                Loop
                
                For h = 1 To fil
                    
                    cLin = ""
                    For j = 1 To icol
                        
                        cLin = cLin & .TableCell(tcText, h, j) & "|"
                    
                    Next j
                    Print #1, cLin
                
                Next h
                cLin = ""
                .TableCell(tcColWidth, 1, 7, fil, 6 + I_Receta.List1.SelCount) = 800: .TableCell(tcAlign, 1, 7, fil, 6 + I_Receta.List1.SelCount) = taRightTop
                .TableCell(tcRows) = fil
                .PenColor = &HC0C0C0
                .TableBorder = tbAll
                totLineas = totLineas + .TableCell(tcRows)
                .EndTable
                cLin = ""
                .StartTable
