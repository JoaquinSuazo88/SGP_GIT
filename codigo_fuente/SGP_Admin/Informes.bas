                .TableCell(tcText, i, 6) = Format((totess / racdia), fg_Pict(9, vg_DCa)): j = i: totess = 0
             End If
             
             i = i + 1
             '-------> Imprimir linea separación estructura servicio
             .TableCell(tcColSpan, i, 1) = 6
             .TableCell(tcText, i, 1) = Space(240)
             .TableCell(tcFontUnderline, i, 1) = True
             i = i + 1
             totess = 0
          End If
                    
          .TableCell(tcFontBold, i) = True
          .TableCell(tcFontSize, i, 1) = 8: .TableCell(tcText, i, 1) = IIf(RS1!ess_codigo = -1, "", RS1!ess_codigo)
          .TableCell(tcFontSize, i, 2) = 8: .TableCell(tcText, i, 2) = IIf(opnomest = True, IIf(IIf(IsNull(RS1!mid_desest) = True, "", RS1!mid_desest) <> "", RS1!mid_desest, RS1!ess_nombre), RS1!ess_nombre) 'Trim(RS1!ess_nombre)
          .TableCell(tcText, i, 3) = ""
          .TableCell(tcText, i, 4) = ""
          i = i + 1
          auxess = RS1!ess_codigo
          nomess = Trim(RS1!ess_nombre)
       End If
       '-------> Recetas
       .TableCell(tcText, i, 1) = RS1!pas_codrec
       .TableCell(tcText, i, 2) = Trim(RS1!pas_nombre)
       .TableCell(tcText, i, 3) = ""
       .TableCell(tcText, i, 4) = Format(RS1!pas_prerec, fg_Pict(9, vg_DPr))
       .TableCell(tcText, i, 5) = Format(RS1!mid_numrac, fg_Pict(9, vg_DPr))
       .TableCell(tcText, i, 6) = Format((RS1!pas_prerec * RS1!mid_numrac), fg_Pict(9, vg_DPr))
       If RS1!pas_prerec <> 0 Then totess = (totess + (RS1!pas_prerec * RS1!mid_numrac)): totdia = (totdia + (RS1!pas_prerec * RS1!mid_numrac))
       racdia = RS1!min_racteo
       RS1.MoveNext: i = i + 1
       .TableCell(tcText, i, 1) = ""
    Loop
    .TableCell(tcColSpan, i, 3) = 3
    .TableCell(tcFontSize, i, 3) = 8: .TableCell(tcFontBold, i, 3) = True: .TableCell(tcText, i, 3) = nomess
    .TableCell(tcFontSize, i, 6) = 8: .TableCell(tcFontBold, i, 6) = True: .TableCell(tcText, i, 6) = Format(totess, fg_Pict(9, vg_DPr))
    i = i + 1
    .TableCell(tcColSpan, i, 3) = 3
    .TableCell(tcFontSize, i, 3) = 8: .TableCell(tcFontBold, i, 3) = True: .TableCell(tcText, i, 3) = "Costo x Estructura"
    .TableCell(tcFontSize, i, 6) = 8: .TableCell(tcFontBold, i, 6) = True: .TableCell(tcText, i, 6) = ""
    
    If racdia > 0 Then
        .TableCell(tcText, i, 6) = Format((totess / racdia), fg_Pict(9, vg_DCa)): j = i: totess = 0
    End If
    
    '-------> Imprimir total día y costo día
    i = i + 2
    .TableCell(tcColSpan, i, 3) = 3
    .TableCell(tcFontSize, i, 3) = 8: .TableCell(tcFontBold, i, 3) = True: .TableCell(tcText, i, 3) = "Costo Total Día"
    .TableCell(tcFontSize, i, 6) = 8: .TableCell(tcFontBold, i, 6) = True: .TableCell(tcText, i, 6) = Format(totdia, fg_Pict(9, vg_DPr))
    i = i + 1
    .TableCell(tcColSpan, i, 3) = 3
    .TableCell(tcFontSize, i, 3) = 8: .TableCell(tcFontBold, i, 3) = True: .TableCell(tcText, i, 3) = "Costo Total Día x Estructura"
    .TableCell(tcFontSize, i, 6) = 8: .TableCell(tcFontBold, i, 6) = True: .TableCell(tcText, i, 6) = ""
    If racdia > 0 Then
       .TableCell(tcText, i, 6) = Format((totdia / racdia), fg_Pict(9, vg_DCa)): j = i: totess = 0
       VecResDia(IndDia, 1) = AuxFec
       VecResDia(IndDia, 2) = VecResDia(IndDia, 2) + (totdia / racdia)
    End If
    .TableCell(tcRows) = i
    .PenColor = &HC0C0C0
    .TableBorder = tbNone
    .EndTable
    
    '-------> Imprimir resumen costo día
    .NewPage
    .StartTable
    .TableCell(tcCols) = 1: .TableCell(tcRows) = 2
    .TableCell(tcColWidth, , 1) = 10500: .TableCell(tcAlign, , 1) = taCenterMiddle
    .TableCell(tcFontSize, 1) = 14: .TableCell(tcFontBold, 1) = True
    .TableCell(tcFontSize, 2) = 8: .TableCell(tcFontBold, 2) = True: .TableCell(tcForeColor, 2) = &H4080&
    .TableCell(tcText, 1, 1) = "Resumen Costos Día Minuta " & " - " & IIf(Indppr = "1", "Real", "Propuesta")
    .TableCell(tcText, 2, 1) = ""
    .TableBorder = tbNone
    .EndTable
    .text = Chr(13): .text = Chr(13)
    .StartTable
    .TableCell(tcCols) = 4: .TableCell(tcRows) = 4
    .TableCell(tcColWidth, , 1) = 1500: .TableCell(tcAlign, , 1) = taLeftTop
    .TableCell(tcColWidth, , 2) = 3300: .TableCell(tcAlign, , 1) = taLeftTop
    .TableCell(tcColWidth, , 3) = 1500: .TableCell(tcAlign, , 1) = taLeftTop
    .TableCell(tcColWidth, , 4) = 4200: .TableCell(tcAlign, , 1) = taLeftTop
    .TableCell(tcFontBold, , 1) = True: .TableCell(tcFontBold, , 3) = True
    .TableCell(tcText, 1, 1) = "Sub-Segmento"
    .TableCell(tcText, 1, 2) = codsub & " - " & nomsub
    .TableCell(tcText, 1, 3) = "Regimen"
    .TableCell(tcText, 1, 4) = codReg & " - " & nomreg
    .TableCell(tcText, 2, 1) = "Servicios"
    .TableCell(tcText, 2, 2) = Trim(auxser) & " - " & Trim(auxnom)
    .TableCell(tcText, 3, 1) = "Zona"
    .TableCell(tcText, 3, 2) = codzon & " - " & nomzon
    .TableCell(tcText, 3, 3) = "Lista Precio"
    .TableCell(tcText, 3, 4) = codlpr & " - " & nomlpr
         
    .TableBorder = tbBoxRows
    .TableBorder = tbNone
    .EndTable
    .FontSize = 7
    .text = Chr(13): .text = Chr(13)
    
    .StartTable
    .TableCell(tcCols) = 2: .TableCell(tcRows) = 1000
    .TableCell(tcColWidth, , 1) = 3500: .TableCell(tcAlign, , 1) = taLeftTop
    .TableCell(tcColWidth, , 2) = 2000: .TableCell(tcAlign, , 2) = taRightTop
    i = 1
    totmes = 0
     For X = 1 To UBound(VecResDia)
         .TableCell(tcFontBold, i, 1) = True: .TableCell(tcText, i, 1) = "Costo Total día x Estructura " & Mid(VecResDia(X, 1), 7, 2) & "/" & Mid(VecResDia(X, 1), 5, 2) & "/" & Mid(VecResDia(X, 1), 1, 4)
         .TableCell(tcFontBold, i, 2) = True: .TableCell(tcText, i, 2) = Format(VecResDia(X, 2), fg_Pict(9, vg_DPr))
         i = i + 1: totmes = totmes + VecResDia(X, 2)
     Next X
     i = i + 2
     .TableCell(tcFontBold, i, 1) = True: .TableCell(tcText, i, 1) = "Costo Promedio x Estructura "
     .TableCell(tcFontBold, i, 2) = True
     
     If UBound(VecResDia) = 0 Then
        .TableCell(tcText, i, 2) = Format(totmes, fg_Pict(9, vg_DPr))
     Else
        .TableCell(tcText, i, 2) = Format(totmes / UBound(VecResDia), fg_Pict(9, vg_DPr))
     End If
    
    .TableCell(tcRows) = i
    .PenColor = &HC0C0C0
    .TableBorder = tbNone '= tbBottom
    .EndTable
    
    RS1.Close: Set RS1 = Nothing
    .EndDoc
End With
Preview.Show 1
fg_descarga
Exit Function
Error_CostoDetMinuta:
    fg_descarga
    MsgBox Err.Number & " " & Err.Description, vbExclamation + vbOKOnly, MsgTitulo
    Close #1
    Exit Function
   Resume
End Function

