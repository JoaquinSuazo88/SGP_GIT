Function ExtraeParentesis(ByVal text As String) As String
ExtraeParentesis = ""

Do While InStr(1, text, "(") <> 0

   text = Mid(text, 1, InStr(1, text, "(") - 1) & IIf(InStr(1, text, ")"), Mid(text, InStr(1, text, ")") + 1, Len(text) - (InStr(1, text, ")") - 1)), "")

Loop
ExtraeParentesis = text
End Function

Function TraeNumeroDiaSemana(Fecha As Long) As Integer
Dim RSNumDia As New ADODB.Recordset
TraeNumeroDiaSemana = 0
Set RSNumDia = vg_db.Execute("select dbo.sgpadm_p_TraeNumDiaSemana(" & Fecha & ")")
If Not (RSNumDia.EOF And RSNumDia.BOF) Then
    RSNumDia.MoveFirst
    TraeNumeroDiaSemana = RSNumDia.Fields(0)
End If
End Function

Function SemanaDeAńo(Fecha As Long) As Integer
Dim RSAux1 As ADODB.Recordset
SemanaDeAńo = 0
    Set RSAux1 = vg_db.Execute("select dbo.sgpadm_p_SemanaAnual (" & Fecha & ") ")
     If Not (RSAux1.EOF And RSAux1.BOF) Then
        RSAux1.MoveFirst
        SemanaDeAńo = RSAux1.Fields(0)
    End If
RSAux1.Close
Set RSAux1 = Nothing

End Function

Function RestarFecha(Fecha As Long, Dias As Integer) As Long
Dim FecAux As String
RestarFecha = 0
    FecAux = DateAdd("d", Dias, CDate(Format$(Format$(Fecha, "##/##/##"), "dd/mm/yy")))
    FecAux = Mid(FecAux, 7, 4) & Mid(FecAux, 4, 2) & Mid(FecAux, 1, 2)
    RestarFecha = Val(FecAux)
End Function


Function TraeNumDiaSemana(Fecha As Long) As Long
Dim RSAux1 As ADODB.Recordset
TraeNumDiaSemana = 0
    Set RSAux1 = vg_db.Execute("select dbo.sgpadm_p_TraeNumDiaSemana (" & Fecha & ") ")
     If Not (RSAux1.EOF And RSAux1.BOF) Then
        RSAux1.MoveFirst
        TraeNumDiaSemana = RSAux1.Fields(0)
    End If
RSAux1.Close
Set RSAux1 = Nothing
End Function

Function RestaFindeSemana(FecIni As Long, FecFin As Long, TipoFinde As Integer) As Long
Dim X As Integer, FecDes As Date, FecHas As Date

FecDes = CDate(Format$(Format$(FecIni, "##/##/##"), "dd/mm/yy"))
FecHas = CDate(Format$(Format$(FecFin, "##/##/##"), "dd/mm/yy"))

X = 0

    Do While FecDes <= FecHas
        Select Case TipoFinde
        Case 7
            If TraeNumDiaSemana(DateLong(FecDes)) = 7 Then
                X = X + 1
            End If
        Case 6
            If TraeNumDiaSemana(DateLong(FecDes)) = 6 And TraeNumDiaSemana(DateLong(FecDes)) = 7 Then
                X = X + 1
            End If
        End Select
        
        FecDes = FecDes + 1
    Loop
    
RestaFindeSemana = X

End Function

Function DateLong(Fecha As Date) As Long

    FecAux = Mid(Fecha, 7, 4) & Mid(Fecha, 4, 2) & Mid(Fecha, 1, 2)
DateLong = FecAux
End Function

