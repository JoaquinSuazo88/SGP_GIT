                        cLin = cLin & "|" & .TableCell(tcText, 1, Col)
                        Col = Col + 1
                    
                    End If
                
                Next X
                Print #1, cLin
                Print #1, " "
                cLin = ""
                .TableBorder = tbNone
                totLineas = totLineas + .TableCell(tcRows)
                .EndTable
                Dim varx As Integer
                varx = IIf(I_Receta.List1.SelCount > 7, 30, 40)
                If totLineas > varx And i <> I_Receta.vaSpread1.MaxRows Then
                    
                    totLineas = 0
                    .NewPage
                
                End If
            End If
            
            RS1.Close
            Set RS1 = Nothing
            I_Receta.ProgressBar1.Value = Val((i / I_Receta.vaSpread1.MaxRows) * 100) 'I_Receta.ProgressBar1.Value + 1
            
        End If
        
    Next i
    .EndDoc
    I_Receta.ProgressBar1.Value = I_Receta.ProgressBar1.Max
    I_Receta.ProgressBar1.Visible = False
    Close #1

