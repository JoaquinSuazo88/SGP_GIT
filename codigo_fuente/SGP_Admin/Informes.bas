    .TableCell(tcCols) = 3: .TableCell(tcRows) = 10000
    .TableCell(tcColWidth, , 1) = 2000: .TableCell(tcAlign, , 1) = taLeftTop
    .TableCell(tcColWidth, , 2) = 5500: .TableCell(tcAlign, , 2) = taLeftTop
    .TableCell(tcColWidth, , 3) = 2000: .TableCell(tcAlign, , 3) = taLeftTop
    i = 1
    If Not RS1.EOF Then
        Do While Not RS1.EOF
            .TableCell(tcText, i, 1) = RS1!sub_codigo
            .TableCell(tcText, i, 2) = RS1!sub_nombre
            .TableCell(tcText, i, 3) = IIf(RS1!sub_indppr = "1", "Real", "Propuesta")
            Print #1, .TableCell(tcText, i, 1) & "|" & .TableCell(tcText, i, 2) & "|" & .TableCell(tcText, i, 3)
            RS1.MoveNext: i = i + 1
        Loop
    Else
        i = i + 1
    End If
    RS1.Close: Set RS1 = Nothing: Close #1
    .TableCell(tcRows) = i
    .TableBorder = tbNone
    .EndTable
    .EndDoc
End With
Preview.Show 1
fg_descarga
Exit Function
Error_SubSeg:
    fg_descarga
    MsgBox Err.Number & " " & Err.Description, vbExclamation + vbOKOnly, MsgTitulo
    Close #1
    Exit Function
End Function


