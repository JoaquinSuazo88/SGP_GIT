' ------------------ samuel melendez -------------------------------------------------------------- 07/09/09
           .TableCell(tcRows) = j
          .TableBorder = tbNone
          .EndTable
'          .EndDoc
          If RS1.EOF Then Exit Do Else .NewPage
       End If
       totess = 0
    Loop
