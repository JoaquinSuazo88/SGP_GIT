Public Function I_CostoDetMinuta(codsub As Long, codReg As Long, codzon As Long, FecIni As Long, FecFin As Long, TipMin As String, opnumrec As Boolean, spid As Long, Usu As String, Indppr As String, opnomest As Boolean, opSemCerrada As Boolean)
Dim auxser As Long, AuxFec As String, auxess As Long, nomess As String, estpag As Boolean, nomsub As String, nomreg As String, nomzon As String, nomlpr As String, codlpr As Long
Dim totess As Double, totdia As Double, racdia As Long, auxnom As String, totmes As Double
Dim i As Long, j As Long, X As Long, IndDia As Long, IniIncDia As Long
Dim VecResDia() As Variant
On Local Error GoTo Error_CostoDetMinuta
fg_carga ""
MsgTitulo = "Costo Detalle Minuta"
Preview.Refresh
Preview.Cls
With Preview.VSPrinter
    .Styles.Apply "Default"
    .ExportFormat = vpxRTF
    .ExportFile = fg_ArchivoRtf 'App.Path & "\Reporte.rtf"
'
'    .ExportFormat = vpxRTF
'    .ExportFile = vg_reporte
    .Preview = True
    .PreviewPage = 1
    .Orientation = orPortrait
    .MarginLeft = 500
    .StartDoc
    .PageBorder = 0
    .HdrFontName = "Arial"
    .HdrFontSize = 8
    .HdrFontBold = False
    .Header = "" & fg_poneencpagina & "||"
    .Footer = "" & fg_ponepiepagina & "||Página : %d"
    ExportHeaderFooter Preview.VSPrinter
    .FontSize = 8
    .PenColor = &HC0C0C0
    LogoEmp
    estpag = False
    nomsub = ""
    RS1.Open "SELECT sub_codigo, sub_nombre FROM a_subsegmento WHERE sub_codigo=" & codsub & "", vg_db, adOpenStatic
    If Not RS1.EOF Then nomsub = Trim(RS1!sub_nombre)
    RS1.Close: Set RS1 = Nothing
    nomreg = ""
    RS1.Open "SELECT reg_codigo, reg_nombre FROM a_regimen WHERE reg_codigo=" & codReg & "", vg_db, adOpenStatic
    If Not RS1.EOF Then nomreg = Trim(RS1!reg_nombre)
    RS1.Close: Set RS1 = Nothing
    nomzon = "": nomlpr = 0: nomlpr = ""
    RS1.Open "SELECT a.zon_nombre, b.lpr_codigo, b.lpr_nombre FROM a_zona a, b_listaprecio b WHERE a.zon_codlpr=b.lpr_codigo AND zon_codigo=" & codzon & "", vg_db, adOpenStatic
    If Not RS1.EOF Then nomzon = Trim(RS1!Zon_nombre): codlpr = RS1!lpr_codigo: nomlpr = Trim(RS1!lpr_nombre)
    RS1.Close: Set RS1 = Nothing
    Set RS1 = vg_db.Execute("sgpadm_s_costoplanmin " & codsub & ", " & codReg & ", " & codzon & ", " & FecIni & ", " & FecFin & ", '" & Usu & "', " & spid & "")
    If RS1.EOF Then fg_descarga: RS1.Close: Set RS1 = Nothing: MsgBox "No existe información, para este periodo", vbExclamation + vbOKOnly, MsgTitulo: Exit Function
    AuxFec = "": auxser = 0: nomess = "": totdia = 0: auxess = 0: racdia = 0: IniIncDia = 1
    i = 1: j = 1: totess = 0: totmes = 0: condia = 0: IndDia = 1
    Do While Not RS1.EOF
       If auxser <> RS1!Ser_codigo Or AuxFec <> RS1!min_fecmin Then
          '-------> Si cambia de regimen, servicio o fecha salto de pagina
          
          If estpag Then
            .TableCell(tcColSpan, i, 3) = 3
            .TableCell(tcFontSize, i, 3) = 8: .TableCell(tcFontBold, i, 3) = True: .TableCell(tcText, i, 3) = nomess
            .TableCell(tcFontSize, i, 6) = 8: .TableCell(tcFontBold, i, 6) = True: .TableCell(tcText, i, 6) = Format(totess, fg_Pict(9, vg_DPr)) 'vg_DCa))
            i = i + 1
            .TableCell(tcColSpan, i, 3) = 3
            .TableCell(tcFontSize, i, 3) = 8: .TableCell(tcFontBold, i, 3) = True: .TableCell(tcText, i, 3) = "Costo x Estructura"
            .TableCell(tcFontSize, i, 6) = 8: .TableCell(tcFontBold, i, 6) = True: .TableCell(tcText, i, 6) = ""
            If racdia > 0 Then
                .TableCell(tcText, i, 6) = Format((totess / racdia), fg_Pict(9, vg_DPr)): j = i
            End If
            totess = 0
            
            '-------> Imprimir total día y costo día
            i = i + 2
            .TableCell(tcColSpan, i, 3) = 3
            .TableCell(tcFontSize, i, 3) = 8: .TableCell(tcFontBold, i, 3) = True: .TableCell(tcText, i, 3) = "Costo Total Día"
            .TableCell(tcFontSize, i, 6) = 8: .TableCell(tcFontBold, i, 6) = True: .TableCell(tcText, i, 6) = Format(totdia, fg_Pict(9, vg_DPr))
            i = i + 1
            .TableCell(tcColSpan, i, 3) = 3
            .TableCell(tcFontSize, i, 3) = 8: .TableCell(tcFontBold, i, 3) = True: .TableCell(tcText, i, 3) = "Costo Total Día x Estructura"
            .TableCell(tcFontSize, i, 6) = 8: .TableCell(tcFontBold, i, 6) = True: .TableCell(tcText, i, 6) = ""
            If racdia > 0 Then
               .TableCell(tcText, i, 6) = Format((totdia / racdia), fg_Pict(9, vg_DPr)): j = i
               VecResDia(IndDia, 1) = AuxFec
               VecResDia(IndDia, 2) = VecResDia(IndDia, 2) + (totdia / racdia)
            End If
            totdia = 0
            
            If AuxFec <> RS1!min_fecmin Then
               IndDia = IndDia + 1
            End If
            .TableCell(tcRows) = i
            .PenColor = &HC0C0C0
            .TableBorder = tbNone '= tbBottom
            .EndTable
            racdia = 0
            .NewPage
            'imprimir total costo día
            If auxser <> RS1!Ser_codigo And auxser > 0 Then
               .StartTable
               .TableCell(tcCols) = 1: .TableCell(tcRows) = 2
               .TableCell(tcColWidth, , 1) = 10500: .TableCell(tcAlign, , 1) = taCenterMiddle
               .TableCell(tcFontSize, 1) = 14: .TableCell(tcFontBold, 1) = True
               .TableCell(tcFontSize, 2) = 8: .TableCell(tcFontBold, 2) = True: .TableCell(tcForeColor, 2) = &H4080&
