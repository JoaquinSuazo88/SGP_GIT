Public Function I_MenuPlanMecanoBloque(cForm As Form, Ceco As String, codReg As Long, FecIni As Long, FecFin As Long, TipMin As String, opnomrec As Boolean, opnomest As Boolean, opSemCerrada As Boolean, opparentesis As Boolean)

Dim i As Long, j As Long, NotA As Long, AsiA As Long, CumA As Long, CerA As Long, codser As Long, AuxFec As Long, auxser As Long
Dim nomser As String, cLin As String, IniIncDia As Long

On Local Error GoTo Error_MecanoBloque

fg_carga ""
MsgTitulo = "Informe Menu Mecano Bloque"
Preview.Refresh
With Preview.VSPrinter
    .Styles.Apply "Default"
    .ExportFormat = vpxRTF
    .ExportFile = fg_ArchivoRtf 'App.Path & "\Reporte.rtf"
    .Preview = True
    .PreviewPage = 1
    .Orientation = orPortrait
    .MarginLeft = 500
    .StartDoc
    .PageBorder = 0
    .HdrFontName = "Arial"
    .HdrFontSize = 15
    .HdrFontBold = True
    .FontSize = 8
    vg_Archxls = fg_ArchivoTxt
    Open vg_Archxls For Output As #1
    fg_carga ""
    
    For i = 1 To cForm.vaSpread1.MaxRows
        
        cForm.vaSpread1.Row = i
        cForm.vaSpread1.Col = 1
        
        If cForm.vaSpread1.text = "1" Then
           
           cForm.vaSpread1.Col = 2
           codser = cForm.vaSpread1.text
           cForm.vaSpread1.Col = 3
           nomser = cForm.vaSpread1.text
           
           If auxser > 0 Then LogoEmp: .NewPage
           
           auxser = 0: j = 1: cLin = ""
                    
           If RS1.State = 1 Then RS1.Close
           RS1.CursorLocation = adUseClient
           vg_db.CursorLocation = adUseClient

           Set RS1 = vg_db.Execute("sgpadm_Sel_InfMecanoMinutaBloque_V02 '" & Ceco & "', " & codReg & ", " & codser & ", " & FecIni & ", " & FecFin & ", '" & TipMin & "', '" & IIf(opnomest, 1, 0) & "' ")
                        
           If Not RS1.EOF Then
                
             IniIncDia = 1
              
              Do While Not RS1.EOF
                 
                 If RS1!min_fecmin <> AuxFec Then
                    
                    If auxser > 0 Then .TableCell(tcRows) = j: .TableBorder = tbNone: .EndTable
                    
                    If opSemCerrada = True And auxser > 0 Then
                        
                        .Footer = "" & "DIA " & IniIncDia & "||Bon Appétit!": Print #1, " "
                        Print #1, vbTab & vbTab & "DIA " & IniIncDia & "||Bon Appétit!" & Chr(13) & Chr(13): .NewPage
                        IniIncDia = IniIncDia + 1
                    
                    ElseIf opSemCerrada = False And auxser > 0 Then
                        
                        .Footer = "" & fg_Fecha_Escrita(Mid(AuxFec, 7, 2) & "/" & Mid(AuxFec, 5, 2) & "/" & Mid(AuxFec, 1, 4)) & "||Bon Appétit!": Print #1, " "
                        Print #1, vbTab & vbTab & fg_Fecha_Escrita(Mid(AuxFec, 7, 2) & "/" & Mid(AuxFec, 5, 2) & "/" & Mid(AuxFec, 1, 4)) & "||Bon Appétit!" & Chr(13) & Chr(13): .NewPage ': LogoEmp
                        IniIncDia = IniIncDia + 1
                    
                    End If
                    
                    .StartTable
                    .TableCell(tcCols) = 1: .TableCell(tcRows) = 2
                    .TableCell(tcColWidth, , 1) = 10500: .TableCell(tcAlign, , 1) = taCenterMiddle
                    
                    If RS2.State = 1 Then RS2.Close
                    RS2.CursorLocation = adUseClient
                    vg_db.CursorLocation = adUseClient
                    
                    RS2.Open "SELECT reg_nombre FROM a_regimen WHERE reg_codigo=" & codReg & "", vg_db, adOpenForwardOnly ', adOpenStatic
                    If RS2.EOF Then fg_descarga: RS2.Close: Set RS2 = Nothing: Close #1: Exit Function
                    
                    .TableCell(tcFontSize, 1) = 14: .TableCell(tcFontBold, 1) = True: .TableCell(tcText, 1, 1) = Trim(RS2!reg_nombre)
                    Print #1, .TableCell(tcText, 1, 1)
                    RS2.Close: Set RS2 = Nothing
                    
                    .TableCell(tcFontSize, 2) = 14: .TableCell(tcFontBold, 2) = True
                    .TableCell(tcText, 2, 1) = nomser
                    Print #1, vbTab & .TableCell(tcText, 2, 1)
                    .TableBorder = tbNone
                    .EndTable
                    .text = Chr(13): .text = Chr(13): .text = Chr(13): .text = Chr(13)
                    AuxFec = RS1!min_fecmin
                    auxser = 0
                    j = 1
                 
                 End If
                 
                 If RS1!mid_estser <> auxser Then
                    
                    If auxser = 0 Then .StartTable
                    
                    .TableCell(tcCols) = 3: .TableCell(tcRows) = 10000
                    .TableCell(tcColWidth, , 1) = 3500: .TableCell(tcAlign, , 1) = taLeftTop
                    .TableCell(tcColWidth, , 2) = 800: .TableCell(tcAlign, , 2) = taLeftTop
                    .TableCell(tcColWidth, , 3) = 5000: .TableCell(tcAlign, , 3) = taLeftTop
                 
                    .TableCell(tcFontSize, j, 1) = 10
                    .TableCell(tcFontBold, j, 1) = True
                    .TableCell(tcText, j, 1) = RS1!ess_nombre 'IIf(opnomest = True, RS1!ess_nombre, RS1!ess_nombre)
                    .TableCell(tcText, j, 2) = "": cLin = ""
                    cLin = cLin & .TableCell(tcText, j, 1) & "|"
                    auxser = RS1!mid_estser
                 
                 End If
                 
                 .TableCell(tcFontSize, j, 3) = 10
                 .TableCell(tcFontBold, j, 3) = True
                 
                 If opnomrec = True Then
                    
                    .TableCell(tcText, j, 3) = IIf(Not opparentesis, ExtraeParentesis(IIf(IsNull(RS1!rec_nomfan) = True, "", RS1!rec_nomfan)), IIf(IsNull(RS1!rec_nomfan) = True, "", RS1!rec_nomfan))
                 
                 Else
                    
                    .TableCell(tcText, j, 3) = IIf(Not opparentesis, ExtraeParentesis(IIf(IsNull(RS1!rec_nombre) = True, "", RS1!rec_nombre)), IIf(IsNull(RS1!rec_nombre) = True, "", RS1!rec_nombre))
                 
                 End If
                 
                 Print #1, cLin & .TableCell(tcText, j, 3)
                 j = j + 1
                 .TableCell(tcFontSize, j, 1) = 10
                 .TableCell(tcFontBold, j, 1) = True
                 .TableCell(tcText, j, 1) = ""
                 .TableCell(tcText, j, 2) = ""
                 .TableCell(tcFontSize, j, 3) = 10
                 .TableCell(tcFontBold, j, 3) = True
                 .TableCell(tcText, j, 3) = ""
                 
                 cLin = "|"
                 
                 RS1.MoveNext
                 
                 j = j + 1
              
              Loop
              
              If opSemCerrada = True And auxser > 0 Then
                    
                 .Footer = "" & "DIA " & IniIncDia & "||Bon Appétit!"
                 Print #1, "DIA " & IniIncDia & "Bon Appétit!" & Chr(13) & Chr(13)
                 .TableCell(tcRows) = j: .TableBorder = tbNone: .EndTable
             
             ElseIf opSemCerrada = False And auxser > 0 Then
                    
                .Footer = "" & fg_Fecha_Escrita(Mid(AuxFec, 7, 2) & "/" & Mid(AuxFec, 5, 2) & "/" & Mid(AuxFec, 1, 4)) & "||Bon Appétit!"
                Print #1, fg_Fecha_Escrita(Mid(AuxFec, 7, 2) & "/" & Mid(AuxFec, 5, 2) & "/" & Mid(AuxFec, 1, 4)) & "Bon Appétit!" & Chr(13) & Chr(13)
                .TableCell(tcRows) = j: .TableBorder = tbNone: .EndTable
            
            End If

           End If
           
           RS1.Close: Set RS1 = Nothing
        
        End If
    Next i
    
    ExportHeaderFooter Preview.VSPrinter
    
    Close #1
    fg_descarga
    .EndDoc

End With
Preview.Show 1

Exit Function
Error_MecanoBloque:
    fg_descarga
    MsgBox Err.Number & " " & Err.Description, vbExclamation + vbOKOnly, MsgTitulo
    Close #1
    Exit Function
    Resume

End Function

