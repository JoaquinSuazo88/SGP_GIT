Public Function I_CostoPlanEstrRes1(codsub As Long, codReg As Long, codzon As Long, FecIni As Long, FecFin As Long, TipMin As String, opnumrec As Boolean, spid As Long, Usu As String, Indppr As String)
Dim auxser As Long, AuxFec As String, auxess As Long, nomess As String, estpag As Boolean, nomsub As String, nomreg As String, nomzon As String, nomlpr As String, codlpr As Long
Dim totess As Double, totdia As Double, racdia As Long, auxnom As String, totmes As Double
Dim i As Long, j As Long, X As Long
Dim VecResDia() As Variant
Dim VecResCos As Variant
Dim a, b, c As Integer
On Local Error GoTo Error_CostoDetMinuta
fg_carga ""
MsgTitulo = "Costo Detalle Minuta"
Preview.Refresh
Preview.Cls
With Preview.VSPrinter
    .Styles.Apply "Default"
    .ExportFormat = vpxRTF
    .ExportFile = fg_ArchivoRtf 'App.Path & "\Reporte.rtf"

    .Preview = True
    .PreviewPage = 1
    .Orientation = orPortrait
    .MarginLeft = 500
    .StartDoc
    .PageBorder = 0
    .HdrFontName = "Arial"
    .HdrFontSize = 8
    .HdrFontBold = False
    .Header = "" & fg_poneencpagina & "||"
    .Footer = "" & fg_ponepiepagina & "||Página : %d"
    ExportHeaderFooter Preview.VSPrinter
    .FontSize = 8
    .PenColor = &HC0C0C0
    LogoEmp
    estpag = False
    nomsub = ""
    RS1.Open "SELECT sub_codigo, sub_nombre FROM a_subsegmento WHERE sub_codigo=" & codsub & "", vg_db, adOpenStatic
    If Not RS1.EOF Then nomsub = Trim(RS1!sub_nombre)
    RS1.Close: Set RS1 = Nothing
    nomreg = ""
    RS1.Open "SELECT reg_codigo, reg_nombre FROM a_regimen WHERE reg_codigo=" & codReg & "", vg_db, adOpenStatic
    If Not RS1.EOF Then nomreg = Trim(RS1!reg_nombre)
    RS1.Close: Set RS1 = Nothing
    nomzon = "": nomlpr = 0: nomlpr = ""
    RS1.Open "SELECT a.zon_nombre, b.lpr_codigo, b.lpr_nombre FROM a_zona a, b_listaprecio b WHERE a.zon_codlpr=b.lpr_codigo AND zon_codigo=" & codzon & "", vg_db, adOpenStatic
    If Not RS1.EOF Then nomzon = Trim(RS1!Zon_nombre): codlpr = RS1!lpr_codigo: nomlpr = Trim(RS1!lpr_nombre)
    RS1.Close: Set RS1 = Nothing
    Set RS1 = vg_db.Execute("sgpadm_s_costoplanmin " & codsub & ", " & codReg & ", " & codzon & ", " & FecIni & ", " & FecFin & ", '" & Usu & "', " & spid & "")
    If RS1.EOF Then fg_descarga: RS1.Close: Set RS1 = Nothing: MsgBox "No existe información, para este periodo", vbExclamation + vbOKOnly, MsgTitulo: Exit Function
    AuxFec = "": auxser = 0: nomess = "": totdia = 0: auxess = 0: racdia = 0
    i = 1: j = 1: totess = 0: totmes = 0: condia = 0: b = 1: c = 1: d = 1
    AuxFec = 0: auxess = 0: auxrec = 0: cntrec = 0
    'RECORREMOS AHORA LOS DATOS Y LLENAMOS VECTOR.
    Do While Not RS1.EOF
        'definir largo del vector
        
        Ser_codigo = RS1!Ser_codigo
        ser_nombre = RS1!ser_nombre
        If i = 1 Then
        Set RS = vg_db.Execute("SELECT COUNT(c.ess_codigo) AS nreg FROM b_minuta a, b_minutadet b, a_estservicio c WHERE a.min_codigo = b.mid_codigo AND b.mid_estser = c.ess_codigo AND a.min_subseg = " & codsub & " AND a.min_codreg = " & codReg & " AND a.min_codser = " & RS1!Ser_codigo & " AND a.min_fecmin >= " & FecIni & " AND a.min_fecmin <= " & FecIni & "")
        If Not RS.EOF Then
           ReDim VecResCos(Val(RS!nReg), 5)
           i = 0
        
        End If
        RS.Close: Set RS = Nothing
        End If
        
        'setear vector
        
        'Se ingresa Codigo Estructura
        If b = 1 Then
        Set RS = vg_db.Execute("SELECT DISTINCT c.ess_codigo, c.ess_nombre FROM b_minuta a, b_minutadet b, a_estservicio c WHERE a.min_codigo = b.mid_codigo AND b.mid_estser = c.ess_codigo AND a.min_subseg = " & codsub & " AND a.min_codreg = " & codReg & " AND a.min_codser = " & RS1!Ser_codigo & " AND a.min_fecmin >= " & FecIni & " AND a.min_fecmin <= " & FecIni & " ")
        Do While Not RS.EOF
           For g = 1 To UBound(VecResCos)
               If Val(VecResCos(g, 1)) = RS!ess_codigo Then
                  Exit For
               ElseIf VecResCos(g, 1) = 0 Then
                  VecResCos(g, 1) = Trim(RS!ess_codigo)
                  VecResCos(g, 2) = Trim(RS!ess_nombre)
                  Exit For
               End If
               
           Next g
           
           RS.MoveNext
        Loop
        RS.Close: Set RS = Nothing
          b = 0
        End If
        'Cargar numero estructura en el peridio
        If c = 1 Then
        Set RS = vg_db.Execute("sgpadm_s_BuscarNumeroEstructura " & codsub & ", " & codReg & ", " & RS1!Ser_codigo & ", " & FecIni & ", " & FecFin & "")
        Do While Not RS.EOF
           For g = 1 To UBound(VecResCos)
               If Val(VecResCos(g, 1)) = RS!mid_estser Then
                  VecResCos(g, 3) = Trim(RS!nReg)
                  Exit For
               End If
           Next g
           RS.MoveNext
        Loop
        RS.Close: Set RS = Nothing
        c = 0
      End If
      If AuxFec <> RS1!min_fecmin Then
        AuxFec = RS1!min_fecmin
      End If
      
       If auxess <> RS1!ess_codigo Then
          
          If cntrec > 0 And auxess <> RS1!ess_codigo Then
            For i = 1 To UBound(VecResCos)
            If Val(VecResCos(i, 1)) = Val(auxess) Then
              VecResCos(i, 4) = (VecResCos(i, 4) + (SumPrerec / cntrec))
              cntrec = 0
              auxrec = 0
              SumPrerec = 0
            End If
            Next i
         End If
         auxess = RS1!ess_codigo
       End If
       If auxrec <> RS1!pas_codrec Then
          cntrec = cntrec + 1
          SumPrerec = SumPrerec + RS1!pas_prerec
       End If
      If d = 1 Then
        .StartTable
        .TableCell(tcCols) = 1: .TableCell(tcRows) = 2
        .TableCell(tcColWidth, , 1) = 9000: .TableCell(tcAlign, , 1) = taCenterMiddle
