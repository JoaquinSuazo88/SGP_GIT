            .TableCell(tcText, 6, 2) = ":"
            .TableCell(tcText, 6, 3) = "Consolidado de Facturación"
            
            .TableCell(tcFontBold, 1, 3) = True: .TableCell(tcFontBold, 2, 3) = True: .TableCell(tcFontBold, 3, 3) = True
            .TableCell(tcFontBold, 4, 3) = True: .TableCell(tcFontBold, 5, 3) = True: .TableCell(tcFontBold, 6, 3) = True
            .EndTable
            RS1.MoveNext
        Loop
    End If
    RS1.Close: Set RS1 = Nothing
    
    .text = Chr(13): .text = Chr(13): .text = Chr(13)
    
    .StartTable
    .TableCell(tcCols) = 10: .TableCell(tcRows) = 1
    .TableCell(tcColWidth, , 1) = 1000: .TableCell(tcAlign, , 1) = taLeftMiddle
    .TableCell(tcColWidth, , 2) = 1000: .TableCell(tcAlign, , 2) = taLeftMiddle
    .TableCell(tcColWidth, , 3) = 5000: .TableCell(tcAlign, , 3) = taLeftMiddle
    .TableCell(tcColWidth, , 4) = 1000: .TableCell(tcAlign, , 4) = taLeftMiddle
    .TableCell(tcColWidth, , 5) = 3000: .TableCell(tcAlign, , 5) = taLeftMiddle
    .TableCell(tcColWidth, , 6) = 900: .TableCell(tcAlign, , 6) = taCenterMiddle
    .TableCell(tcColWidth, , 7) = 1000: .TableCell(tcAlign, , 7) = taCenterMiddle
    .TableCell(tcColWidth, , 8) = 1000: .TableCell(tcAlign, , 8) = taCenterMiddle
    .TableCell(tcColWidth, , 9) = 1000: .TableCell(tcAlign, , 9) = taCenterMiddle
    .TableCell(tcColWidth, , 10) = 1100: .TableCell(tcAlign, , 10) = taCenterMiddle
    
    .TableCell(tcBackColor, 1) = vbYellow: .TableCell(tcFontBold, 1) = True: .TableCell(tcRowHeight, 1) = 700
    .TableCell(tcText, 1, 1) = "Nro. Guía o Factura"
    .TableCell(tcText, 1, 2) = "Mes"
    .TableCell(tcText, 1, 3) = "Descripción Producto"
    .TableCell(tcText, 1, 4) = "Medida Compra"
    .TableCell(tcText, 1, 5) = "Familia"
    .TableCell(tcText, 1, 6) = "Precio"
    .TableCell(tcText, 1, 7) = "Total Cantidad"
    .TableCell(tcText, 1, 8) = "Total Factura"
    .TableCell(tcText, 1, 9) = "Peso por Familia de Producto"
    .TableCell(tcText, 1, 10) = "Peso por Total de Facturación"
    
    Print #1, .TableCell(tcText, 1, 1) & "|" & .TableCell(tcText, 1, 2) & "|" & .TableCell(tcText, 1, 3) & "|" & _
              .TableCell(tcText, 1, 4) & "|" & .TableCell(tcText, 1, 5) & "|" & .TableCell(tcText, 1, 6) & "|" & _
              .TableCell(tcText, 1, 7) & "|" & .TableCell(tcText, 1, 8) & "|" & .TableCell(tcText, 1, 9) & "|" & _
              .TableCell(tcText, 1, 10) & "|"

    .TableBorder = tbAll
    .EndTable
    
    
    .StartTable
    .TableCell(tcCols) = 10: .TableCell(tcRows) = 10000
    .TableCell(tcRowHeight, 0, 1) = 2000
    .TableCell(tcColWidth, , 1) = 1000: .TableCell(tcAlign, , 1) = taLeftTop
    .TableCell(tcColWidth, , 2) = 1000: .TableCell(tcAlign, , 2) = taLeftTop
    .TableCell(tcColWidth, , 3) = 5000: .TableCell(tcAlign, , 3) = taLeftTop
    .TableCell(tcColWidth, , 4) = 1000: .TableCell(tcAlign, , 4) = taLeftTop
    .TableCell(tcColWidth, , 5) = 3000: .TableCell(tcAlign, , 5) = taLeftTop
    .TableCell(tcColWidth, , 6) = 900: .TableCell(tcAlign, , 6) = taRightTop
    .TableCell(tcColWidth, , 7) = 1000: .TableCell(tcAlign, , 7) = taRightTop
    .TableCell(tcColWidth, , 8) = 1000: .TableCell(tcAlign, , 8) = taRightTop
    .TableCell(tcColWidth, , 9) = 1000: .TableCell(tcAlign, , 9) = taRightTop
    .TableCell(tcColWidth, , 10) = 1100: .TableCell(tcAlign, , 10) = taRightTop
    
    i = 1
    strSQL = "ssll_s_consolfactura " & "'" & periodo & "', '" & cencos & "'"
    Set RS1 = vg_db.Execute(strSQL)
    
    wvarDesdePosicion = 1
    wvarTotalFacturacion = 0
    
    If Not RS1.EOF Then
        Do While Not RS1.EOF
            
            If (wvarAgrupaFamilia <> Trim(RS1!fampro) And i <> 1) Then
                SumaPorFamilia = 0
                wvarDesdePosicion = wvarDesdePosicion
                
                For j = wvarDesdePosicion To i - 1
                    SumaPorFamilia = Val(CDbl(SumaPorFamilia)) + Val(CDbl(.TableCell(tcText, j, 8)))
                Next j
                
                .TableCell(tcText, i, 3) = "SUBTOTAL " & wvarFamPrimerNivel
                .TableCell(tcText, i, 8) = Format(Val(SumaPorFamilia), fg_Pict(9, 2))
                .TableCell(tcFontBold, i, 3) = True: .TableCell(tcFontBold, i, 8) = True
                .TableCell(tcBackColor, i) = &HCCFFFF
                
                For j = wvarDesdePosicion To i - 1
                    wvarPesoPorFamilia = (Val(CDbl(.TableCell(tcText, j, 8))) / SumaPorFamilia) * 100
                    .TableCell(tcText, j, 9) = Format(wvarPesoPorFamilia, "0.00")
                Next j
                
                i = i + 2
                wvarDesdePosicion = i
                wvarTotalFacturacion = wvarTotalFacturacion + SumaPorFamilia
            End If
            
            .TableCell(tcText, i, 1) = Trim(RS1!numdoc)
            .TableCell(tcText, i, 2) = M_SsllIPA.AsignaMesStr(periodo)
            .TableCell(tcText, i, 3) = Trim(RS1!nomsac)
            
            If RS1!unimed = "" Then
                wvarunidad = 0
            Else
                wvarunidad = RS1!unimed
            End If
            
            .TableCell(tcText, i, 4) = Trim(RS1!foc_unisac)
            
            wvarAgrupaFamilia = Trim(RS1!fampro)
            
            Dim ArregloConsFact() As String
            ArregloConsFact = Split(Trim(RS1!fampro), "\")
            wvarFamPrimerNivel = ArregloConsFact(1)
            
            .TableCell(tcText, i, 5) = Trim(wvarFamPrimerNivel)
            .TableCell(tcText, i, 6) = Format(Val(CDbl(RS1!precos)), fg_Pict(9, 2))
            .TableCell(tcText, i, 7) = Format(Val(CDbl(RS1!canmer)), fg_Pict(9, 2))
            .TableCell(tcText, i, 8) = Format(Val(CDbl(RS1!totpro)), fg_Pict(9, 2))
            
            Print #1, .TableCell(tcText, i, 1) & "|" & .TableCell(tcText, i, 2) & "|" & .TableCell(tcText, i, 3) & _
                "|" & .TableCell(tcText, i, 4) & "|" & .TableCell(tcText, i, 5) & "|" & .TableCell(tcText, i, 6) & "|" & _
                "|" & .TableCell(tcText, i, 7) & "|" & .TableCell(tcText, i, 8) & "|" & .TableCell(tcText, i, 9) & "|" & _
                "|" & .TableCell(tcText, i, 10) & "|"
            RS1.MoveNext
            
            If RS1.EOF Then
                SumaPorFamilia = 0
                i = i + 1
                wvarDesdePosicion = wvarDesdePosicion
                
                For j = wvarDesdePosicion To i - 1
                    If Trim(.TableCell(tcText, j, 8)) <> "" Then
                       SumaPorFamilia = Val(CDbl(SumaPorFamilia)) + Val(CDbl(.TableCell(tcText, j, 8)))
                    End If
                Next j
                
                .TableCell(tcText, i, 3) = "SUBTOTAL " & wvarFamPrimerNivel
                .TableCell(tcText, i, 8) = Format(SumaPorFamilia, fg_Pict(9, 2))
                .TableCell(tcFontBold, i, 3) = True: .TableCell(tcFontBold, i, 8) = True
                .TableCell(tcBackColor, i) = &HCCFFFF
                
                For j = wvarDesdePosicion To i - 1
                    If Trim(.TableCell(tcText, j, 8)) <> "" Then
                       wvarPesoPorFamilia = (Val(CDbl(.TableCell(tcText, j, 8))) / SumaPorFamilia) * 100
                    End If
                    .TableCell(tcText, j, 9) = Format(wvarPesoPorFamilia, "0.00")
                Next j
                
                wvarTotalFacturacion = wvarTotalFacturacion + SumaPorFamilia
            End If
            
            i = i + 1
        Loop
    Else
        i = i + 1
    End If
    RS1.Close: Set RS1 = Nothing

'---Total-Productos------------------------------------------------------------------------------------------
    i = i + 2
    .TableCell(tcRows) = i
    .TableCell(tcText, i, 3) = "TOTAL FACTURACION"
    .TableCell(tcFontBold, i, 3) = True
    .TableCell(tcAlign, i, 8) = taRightTop
    .TableCell(tcText, i, 8) = Format(Val(CDbl(wvarTotalFacturacion)), fg_Pict(9, 2))
    .TableCell(tcFontBold, i, 8) = True
    .TableCell(tcBackColor, i) = &HCCFFFF
    
    For k = 1 To i
        If (Trim(.TableCell(tcText, k, 1)) <> "" And Trim(.TableCell(tcText, k, 8)) <> "") Then
            wvarPesoPorTotalFact = (Val(CDbl(.TableCell(tcText, k, 8))) / Format(Val(CDbl(wvarTotalFacturacion)), "##,##")) * 100
            .TableCell(tcText, k, 10) = Format(wvarPesoPorTotalFact, "0.00")
        End If
    Next k
    
    Print #1, .TableCell(tcText, i, 1) & "|" & .TableCell(tcText, i, 2) & "|" & .TableCell(tcText, i, 3) & _
        "|" & .TableCell(tcText, i, 4) & "|" & .TableCell(tcText, i, 5) & "|" & .TableCell(tcText, i, 6) & "|" & _
        "|" & .TableCell(tcText, i, 7) & "|" & .TableCell(tcText, i, 8) & "|" & .TableCell(tcText, i, 9) & "|" & _
        "|" & .TableCell(tcText, i, 10) & "|"
''------------------------------------------------------------------------------------------------------------

    .TableCell(tcRows) = i
    .PenColor = &HC0C0C0
    .TableBorder = tbAll
    .EndTable
    .EndDoc
    Close #1
End With
Preview.Show 1
fg_descarga
Exit Function
Error_ConsolFact:
    fg_descarga
    MsgBox Err.Number & " " & Err.Description, vbExclamation + vbOKOnly, MsgTitulo
    Close #1
    Exit Function
End Function

