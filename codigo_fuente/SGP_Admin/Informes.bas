                    .TableCell(tcText, j, 3) = Format((VecResDia(j, 4) / Val(VecResDia(j, 3))), fg_Pict(9, vg_DCa))
                 End If
                 
                If VecResDia(j, 3) = 0 Then
                    totess = totess + Format(0, fg_Pict(9, vg_DCa))
                Else
                    totess = totess + Format((VecResDia(j, 4) / Val(VecResDia(j, 3))), fg_Pict(9, vg_DCa))
                End If
                 
              ElseIf VecResDia(j, 1) = 0 Then
