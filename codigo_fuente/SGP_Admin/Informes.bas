                    For p = 1 To j
                        If .TableCell(tcText, p, 1) = RS1!ess_nombre Then essnom = True: cLin = "": Exit For
                    Next p
                    If essnom = False Then .TableCell(tcText, j, 1) = IIf(opnomest = True, IIf(IIf(IsNull(RS1!mid_desest) = True, "", RS1!mid_desest) <> "", RS1!mid_desest, RS1!ess_nombre), RS1!ess_nombre): cLin = .TableCell(tcText, j, 1)
                    '------- Fin revisar si existe una estructura fija
                    auxser = RS1!mid_estser
                 End If
                 If Val(Mid(RS1!min_fecmin, 7, 2)) >= 1 And Val(Mid(RS1!min_fecmin, 7, 2)) <= 7 Then
                    xx = Val(Mid(RS1!min_fecmin, 7, 2))
                 ElseIf Val(Mid(RS1!min_fecmin, 7, 2)) >= 8 And Val(Mid(RS1!min_fecmin, 7, 2)) <= 14 Then
