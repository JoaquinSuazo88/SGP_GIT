                    xx = Val(Mid(RS1!min_fecmin, 7, 2)) - 21
                 ElseIf Val(Mid(RS1!min_fecmin, 7, 2)) >= 29 And Val(Mid(RS1!min_fecmin, 7, 2)) <= 35 Then
                    xx = Val(Mid(RS1!min_fecmin, 7, 2)) - 28
                 End If
                 .TableCell(tcText, j, xx + 1) = IIf(opnomrec = True, IIf(Not opparentesis, ExtraeParentesis(IIf(IsNull(RS1!rec_nomfan) = True, "", RS1!rec_nomfan)), IIf(IsNull(RS1!rec_nomfan) = True, "", RS1!rec_nomfan)) & " " & IIf(Raciones = 1, "( " & RS1!mid_numrac & " raciones)", "") & " " & IIf(Costo = 1, " - Costo uni. $ " & Format((RS1!mid_cosrec), fg_Pict(6, 2)), ""), IIf(Not opparentesis, ExtraeParentesis(IIf(IsNull(RS1!rec_nombre) = True, "", RS1!rec_nombre)), IIf(IsNull(RS1!rec_nombre) = True, "", RS1!rec_nombre)) & " " & IIf(Raciones = 1, "( " & RS1!mid_numrac & " raciones)", "") & " " & IIf(Costo = 1, " - Costo uni. $ " & Format((RS1!mid_cosrec), fg_Pict(6, 2)), ""))
                 
'                  FecAux = RS1!min_fecmin
                 RS1.MoveNext
