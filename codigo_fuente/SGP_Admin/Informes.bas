On Local Error GoTo Error_ReglasdeNegociosFamilia
MsgTitulo = "Informe de Familia Reglas de Negocios"
With Preview.VSPrinter
    .Styles.Apply "Default"
    .ExportFormat = vpxRTF
    .ExportFile = fg_ArchivoRtf 'App.Path & "\Reporte.rtf"
    .Preview = True
    .PreviewPage = 1
    .Orientation = orLandscape
    .MarginLeft = 500
    .StartDoc
    .PageBorder = 0
    .HdrFontName = "Arial"
    .HdrFontSize = 8
    .HdrFontBold = False
    .Header = "||"
    .Footer = "" & fg_ponepiepagina & "||Página : %d"
    ExportHeaderFooter Preview.VSPrinter
    vg_Archxls = fg_ArchivoTxt
    Open vg_Archxls For Output As #1
    LogoEmp
    .FontSize = 8
    estsal = False
    I_WebRep.ProgressBar1.Scrolling = ccScrollingStandard
    I_WebRep.ProgressBar1.Max = cuenta
    I_WebRep.ProgressBar1.Visible = True
    I_WebRep.ProgressBar1.Value = 0
    For X = 1 To I_WebRep.vaSpread1.MaxRows
        I_WebRep.vaSpread1.Row = X
        I_WebRep.vaSpread1.Col = 1
        If I_WebRep.vaSpread1.text = "1" Then
           If estsal Then .NewPage
           estsal = True
           I_WebRep.vaSpread1.Col = 2
           codigo = Val(I_WebRep.vaSpread1.text)
             .StartTable
             .TableCell(tcCols) = 1: .TableCell(tcRows) = 1
             .TableCell(tcColWidth, , 1) = 13500: .TableCell(tcAlign, , 1) = taCenterMiddle
             .TableCell(tcFontSize, 1) = 14: .TableCell(tcFontBold, 1) = True
             .TableCell(tcText, 1, 1) = "Maestro Familia Reglas de Negocios"
             Print #1, .TableCell(tcText, 1, 1)
             .TableBorder = tbNone
             .EndTable
             .text = Chr(13): .text = Chr(13)
             
             Set RS1 = vg_dbpedweb.Execute("pedweb_s_reglasdenegocios 4, " & codigo & ", ''")
             If RS1.EOF Then RS1.Close: Set RS1 = Nothing ': Close #1: Exit Function
             .StartTable
             .TableCell(tcCols) = 2: .TableCell(tcRows) = 1
             .TableCell(tcColWidth, , 1) = 1000: .TableCell(tcAlign, , 1) = taLeftTop
             .TableCell(tcColWidth, , 2) = 6500: .TableCell(tcAlign, , 2) = taLeftTop
             .TableCell(tcFontBold, 1) = True: .TableCell(tcRowHeight, 1) = 230
             .TableCell(tcText, 1, 1) = "Reglas Negocios : "
             .TableCell(tcText, 1, 2) = RS1!rn_codigo & " - " & Trim(RS1!rn_nombre) & " - " & IIf(RS1!rn_tipo_ruta = "1", "Con Ruta", IIf(RS1!rn_tipo_ruta = "2", "Sin Ruta", "Con y Sin Rutas"))
             Print #1, .TableCell(tcText, 1, 1) & "|" & .TableCell(tcText, 1, 2)
             .TableBorder = tbNone
             .EndTable
             RS1.Close: Set RS1 = Nothing
            .text = Chr(13): .text = Chr(13)
             
             Set RS1 = vg_dbpedweb.Execute("pedweb_s_reglasdenegociosfamilia 1, " & codigo & "")
             If RS1.EOF Then
                RS1.Close: Set RS1 = Nothing ': Close #1: Exit Function
             Else
             .StartTable
             .TableCell(tcCols) = 6: .TableCell(tcRows) = 1
             .TableCell(tcColWidth, , 1) = 1000: .TableCell(tcAlign, , 1) = taCenterTop
             .TableCell(tcColWidth, , 2) = 1000: .TableCell(tcAlign, , 2) = taLeftTop
             .TableCell(tcColWidth, , 3) = 5500: .TableCell(tcAlign, , 3) = taLeftTop
             .TableCell(tcColWidth, , 4) = 1000: .TableCell(tcAlign, , 4) = taCenterTop
             .TableCell(tcColWidth, , 5) = 1000: .TableCell(tcAlign, , 5) = taCenterTop
             .TableCell(tcColWidth, , 6) = 1000: .TableCell(tcAlign, , 6) = taCenterTop
             .TableCell(tcBackColor, 1) = vbYellow: .TableCell(tcFontBold, 1) = True: .TableCell(tcRowHeight, 1) = 230
             .TableCell(tcText, 1, 1) = "Bloqueado"
             .TableCell(tcText, 1, 2) = "Código"
             .TableCell(tcText, 1, 3) = "Descripción"
             .TableCell(tcText, 1, 4) = "PN"
             .TableCell(tcText, 1, 5) = "PA"
             .TableCell(tcText, 1, 6) = "A"
             Print #1, .TableCell(tcText, 1, 1) & "|" & .TableCell(tcText, 1, 2) & "|" & .TableCell(tcText, 1, 3) & "|" & .TableCell(tcText, 1, 4) & "|" & .TableCell(tcText, 1, 5) & "|" & .TableCell(tcText, 1, 6)
             .TableBorder = tbBox
             .EndTable
             .StartTable
             .TableCell(tcCols) = 6: .TableCell(tcRows) = 10000
             .TableCell(tcColWidth, , 1) = 1000: .TableCell(tcAlign, , 1) = taCenterTop
             .TableCell(tcColWidth, , 2) = 1000: .TableCell(tcAlign, , 2) = taLeftTop
             .TableCell(tcColWidth, , 3) = 5500: .TableCell(tcAlign, , 3) = taLeftTop
             .TableCell(tcColWidth, , 4) = 1000: .TableCell(tcAlign, , 4) = taCenterTop
             .TableCell(tcColWidth, , 5) = 1000: .TableCell(tcAlign, , 5) = taCenterTop
             .TableCell(tcColWidth, , 6) = 1000: .TableCell(tcAlign, , 6) = taCenterTop
             i = 1: estmar = False
             If Not RS1.EOF Then
                 Do While Not RS1.EOF
                    If auxfam <> RS1!codigo Then
                       If estmar Then
                          .TableCell(tcText, i, 1) = "X"
                          Print #1, .TableCell(tcText, i, 1) & "|" & .TableCell(tcText, i, 2) & "|" & .TableCell(tcText, i, 3) & "|" & .TableCell(tcText, i, 4) & "|" & .TableCell(tcText, i, 5) & "|" & .TableCell(tcText, i, 6)
                       End If
                       If Trim(auxfam) <> "" Then
                          i = i + 1
                       End If
                       estmar = False
                       .TableCell(tcText, i, 2) = Trim(RS1!codigo)
                       .TableCell(tcText, i, 3) = Trim(IIf(IsNull(RS1!descripcioncompleta), "", RS1!descripcioncompleta))
                       auxfam = RS1!codigo
                    End If
                    .TableCell(tcText, i, 4) = IIf(IsNull(RS1!rnf_pn) Or RS1!rnf_pn = "N", "", "X")
                     If Not IsNull(RS1!rnf_pn) Then estmar = True
                    .TableCell(tcText, i, 5) = IIf(IsNull(RS1!rnf_pa) Or RS1!rnf_pa = "N", "", "X")
                     If Not IsNull(RS1!rnf_pa) Then estmar = True
                    .TableCell(tcText, i, 6) = IIf(IsNull(RS1!rnf_a) Or RS1!rnf_a = "N", "", "X")
                     If Not IsNull(RS1!rnf_a) Then estmar = True
                     RS1.MoveNext
                 Loop
             Else
                 i = i + 1
             End If
             If estmar Then
                .TableCell(tcText, i, 1) = "X"
                Print #1, .TableCell(tcText, i, 1) & "|" & .TableCell(tcText, i, 2) & "|" & .TableCell(tcText, i, 3) & "|" & .TableCell(tcText, i, 4) & "|" & .TableCell(tcText, i, 5) & "|" & .TableCell(tcText, i, 6)
             End If
             RS1.Close: Set RS1 = Nothing
             .TableCell(tcRows) = i
             .TableBorder = tbNone
             .EndTable
             End If
             I_WebRep.ProgressBar1.Value = I_WebRep.ProgressBar1.Value + 1
        End If
    Next X
    I_WebRep.ProgressBar1.Value = I_WebRep.ProgressBar1.Max
    I_WebRep.ProgressBar1.Visible = False
    .EndDoc
    Close #1
    Preview.Show 1
    Preview.Refresh
End With
Exit Function
Error_ReglasdeNegociosFamilia:
    MsgBox Err.Number & " " & Err.Description, vbExclamation + vbOKOnly, MsgTitulo
    Close #1
    Exit Function
End Function

