        .TableCell(tcText, 1, 1) = "Resumen Promedio de Costos Minuta " & " - " & IIf(Indppr = "1", "Real", "Propuesta")
        .TableCell(tcText, 2, 1) = ""
        .TableBorder = tbNone
        .EndTable
       
       .StartTable
       .TableCell(tcCols) = 4: .TableCell(tcRows) = 5
       .TableCell(tcColWidth, , 1) = 1500: .TableCell(tcAlign, , 1) = taLeftTop
       .TableCell(tcColWidth, , 2) = 3300: .TableCell(tcAlign, , 1) = taLeftTop
       .TableCell(tcColWidth, , 3) = 1500: .TableCell(tcAlign, , 1) = taLeftTop
       .TableCell(tcColWidth, , 4) = 4200: .TableCell(tcAlign, , 1) = taLeftTop
       .TableCell(tcFontBold, , 1) = True: .TableCell(tcFontBold, , 3) = True
       .TableCell(tcText, 1, 1) = "Sub-Segmento"
       .TableCell(tcText, 1, 2) = codsub & " - " & nomsub
       .TableCell(tcText, 1, 3) = "Regimen"
       .TableCell(tcText, 1, 4) = codReg & " - " & nomreg
       .TableCell(tcText, 2, 1) = "Servicios"
       .TableCell(tcText, 2, 2) = Trim(RS1!Ser_codigo) & " - " & Trim(RS1!ser_nombre)
       .TableCell(tcText, 2, 3) = "Fecha Minuta"
       .TableCell(tcText, 2, 4) = fg_Ctod1(RS1!min_fecmin) & " a " & FecFin
       .TableCell(tcText, 3, 1) = "Zona"
       .TableCell(tcText, 3, 2) = codzon & " - " & nomzon
       .TableCell(tcText, 3, 3) = "Lista Precio"
       .TableCell(tcText, 3, 4) = codlpr & " - " & nomlpr
       .TableCell(tcText, 4, 1) = "Rac. Efectivas"
       .TableCell(tcText, 4, 2) = RS1!min_racteo
       .TableCell(tcText, 5, 1) = ""
       .TableBorder = tbBoxRows
       .TableBorder = tbNone
       .EndTable
       .FontSize = 7
       d = 0
     End If
       RS1.MoveNext
    Loop
RS1.Close: Set RS1 = Nothing

.StartTable
.TableCell(tcCols) = 3: .TableCell(tcRows) = 1
.TableCell(tcColWidth, , 1) = 9000: .TableCell(tcAlign, , 1) = taCenterMiddle
.TableCell(tcColWidth, , 1) = 2000: .TableCell(tcAlign, , 1) = taLeftTop
.TableCell(tcColWidth, , 2) = 5000: .TableCell(tcAlign, , 2) = taLeftTop
.TableCell(tcColWidth, , 3) = 2000: .TableCell(tcAlign, , 3) = taCenterTop
.TableCell(tcBackColor, 1) = vbYellow: .TableCell(tcFontBold, 1) = True: .TableCell(tcRowHeight, 1) = 230
.TableCell(tcText, 1, 1) = "Código"
.TableCell(tcText, 1, 2) = "Descripción"
.TableCell(tcText, 1, 3) = "Costo"
.TableBorder = tbAll
.EndTable
    
.StartTable
.TableCell(tcCols) = 3: .TableCell(tcRows) = UBound(VecResCos)
.TableCell(tcColWidth, , 1) = 9000: .TableCell(tcAlign, , 1) = taCenterMiddle
.TableCell(tcColWidth, , 1) = 2000: .TableCell(tcAlign, , 1) = taLeftTop
.TableCell(tcColWidth, , 2) = 5000: .TableCell(tcAlign, , 2) = taLeftTop
.TableCell(tcColWidth, , 3) = 2000: .TableCell(tcAlign, , 3) = taCenterTop
For j = 1 To UBound(VecResCos)
  If Trim(VecResCos(j, 1)) <> "" Then
     .TableCell(tcFontSize, j, 1) = 8: .TableCell(tcFontBold, j, 1) = False: .TableCell(tcText, j, 1) = VecResCos(j, 1)
     .TableCell(tcFontSize, j, 2) = 8: .TableCell(tcFontBold, j, 2) = False: .TableCell(tcText, j, 2) = VecResCos(j, 2)
     .TableCell(tcFontSize, j, 3) = 8: .TableCell(tcFontBold, j, 3) = False: .TableCell(tcText, j, 3) = Format((VecResCos(j, 4) / Val(VecResCos(j, 3))), fg_Pict(9, vg_DCa))
  End If
Next j
.EndTable
.EndDoc
End With
Close #1
Preview.Show 1
fg_descarga
Exit Function
