Dim i As Long, NotA As Long, AsiA As Long, CumA As Long, CerA As Long
On Local Error GoTo Error_DsctoxVol
fg_carga ""
MsgTitulo = "EMITIR NOTA DE VENTA"
Preview.Refresh
With Preview.VSPrinter
    .Styles.Apply "Default"
    .ExportFormat = vpxRTF
    .ExportFile = fg_ArchivoRtf 'App.Path & "\Reporte.rtf"
    .Preview = True
    .PreviewPage = 1
    .Orientation = orPortrait
    .MarginLeft = 500
    .StartDoc
    .PageBorder = 0
    .HdrFontName = "Arial"
    .HdrFontSize = 8
    .HdrFontBold = False
    .Footer = "" & Format(Time, "hh:mm") & "||Página : %d"
    ExportHeaderFooter Preview.VSPrinter
    .FontSize = 7
    vg_Archxls = fg_ArchivoTxt
    Open vg_Archxls For Output As #1
    LogoEmp
    
    strSQL = "SELECT * FROM b_clientes With(NoLock) WHERE cli_codigo = '" & cencos & "'"
    Set RS1 = vg_db.Execute(strSQL)
    
    If Not RS1.EOF Then
        Do While Not RS1.EOF
            .StartTable
            .TableBorder = tbNone
            .TableCell(tcCols) = 1: .TableCell(tcRows) = 1
            .TableCell(tcCols) = 3: .TableCell(tcRows) = 7
            .TableCell(tcColWidth, , 1) = 2200: .TableCell(tcAlign, , 1) = taLeftTop
            .TableCell(tcColWidth, , 2) = 300: .TableCell(tcAlign, , 2) = taLeftTop
            .TableCell(tcColWidth, , 3) = 8400: .TableCell(tcAlign, , 3) = taLeftTop
            
            .TableCell(tcText, 1, 1) = "Código Centro de Costo"
            .TableCell(tcText, 1, 2) = " : "
            .TableCell(tcText, 1, 3) = RS1!Cli_codigo
            
            .TableCell(tcText, 2, 1) = "Nombre Centro de Costo"
            .TableCell(tcText, 2, 2) = " : "
            .TableCell(tcText, 2, 3) = UCase(RS1!Cli_nombre)
            
            .TableCell(tcText, 3, 1) = "Dirección"
            .TableCell(tcText, 3, 2) = " : "
            .TableCell(tcText, 3, 3) = UCase(RS1!cli_direccion) & " - " & UCase(RS1!cli_ciudad)
            
            .TableCell(tcText, 4, 1) = "Giro"
            .TableCell(tcText, 4, 2) = " : "
            .TableCell(tcText, 4, 3) = RS1!cli_giro
            
            .TableCell(tcText, 5, 1) = "Periodo"
            .TableCell(tcText, 5, 2) = " : "
            .TableCell(tcText, 5, 3) = Mid(periodo, 5, 2) & "/" & Mid(periodo, 1, 4)
    
            .TableCell(tcText, 7, 1) = "30 días"
            .TableCell(tcText, 7, 2) = ""
            .TableCell(tcText, 7, 3) = Format(Date, "dd/mm/yyyy"):  .TableCell(tcAlign, 7, 3) = taRightMiddle
            
            .TableCell(tcFontBold, , 3) = True: .TableCell(tcFontBold, 7, 3) = False
            .EndTable
            RS1.MoveNext
        Loop
    End If
    RS1.Close: Set RS1 = Nothing: .text = Chr(13)
    
    
'---------------------------------------------------------------------------------------------------------------------
    
    .StartTable
    .TableCell(tcCols) = 5: .TableCell(tcRows) = 10000
    .TableCell(tcColWidth, , 1) = 1000: .TableCell(tcAlign, , 1) = taRightMiddle
    .TableCell(tcColWidth, , 2) = 1200: .TableCell(tcAlign, , 2) = taLeftMiddle
    .TableCell(tcColWidth, , 3) = 5500: .TableCell(tcAlign, , 3) = taLeftMiddle
    .TableCell(tcColWidth, , 4) = 1200: .TableCell(tcAlign, , 4) = taRightMiddle
    .TableCell(tcColWidth, , 5) = 2000: .TableCell(tcAlign, , 5) = taRightMiddle
    .TableCell(tcAlign, 1, 1) = taCenterMiddle: .TableCell(tcAlign, 1, 4) = taCenterMiddle: .TableCell(tcAlign, 1, 5) = taCenterMiddle
    

    .TableCell(tcBackColor, 1) = vbYellow: .TableCell(tcFontBold, 1) = True: .TableCell(tcRowHeight, 1) = 700
    .TableCell(tcText, 1, 1) = "Cantidad"
    .TableCell(tcText, 1, 2) = "Unidad Medida"
    .TableCell(tcText, 1, 3) = "Descripción"
    .TableCell(tcText, 1, 4) = "Precio Unitario"
    .TableCell(tcText, 1, 5) = "Valor Total"
    
    Print #1, .TableCell(tcText, 1, 1) & "|" & .TableCell(tcText, 1, 2) & "|" & .TableCell(tcText, 1, 3) & "|" & _
         "" & .TableCell(tcText, 1, 4) & "|" & .TableCell(tcText, 1, 5) & "|"
    
    
    i = 2
    strSQL = "ssll_s_NotaVentaxFamilia02 " & "'" & periodo & "', '" & cencos & "'"
    Set RS1 = vg_db.Execute(strSQL)
        
    If Not RS1.EOF Then
        Do While Not RS1.EOF
            .TableCell(tcText, i, 1) = Format(Val(CDbl(RS1!canmer)), "##,##")
            
            If RS1!unimed = "" Then
                wvarunidad = 0
            Else
                wvarunidad = RS1!unimed
            End If
            
            .TableCell(tcText, i, 2) = Trim(RS1!foc_unisac)
            
            If RS1!codpro = "" Then
                wvarcodpro = "0"
            Else
                wvarcodpro = RS1!codprodsac
            End If
            
            .TableCell(tcText, i, 3) = Trim(RS1!foc_nomsac)
            
            .TableCell(tcText, i, 4) = Format(Val(RS1!precos), "##,##")
            .TableCell(tcText, i, 5) = Format(Val(CDbl(RS1!canmer)) * Val(CDbl(RS1!precos)), "##,##")

            Print #1, .TableCell(tcText, i, 1) & "|" & .TableCell(tcText, i, 2) & "|" & .TableCell(tcText, i, 3) & _
                "|" & .TableCell(tcText, i, 4) & "|" & .TableCell(tcText, i, 5) & "|"
            RS1.MoveNext: i = i + 1
        Loop
    Else
        i = i + 1
    End If
    RS1.Close: Set RS1 = Nothing
    
'---Total-Productos------------------------------------------------------------------------------------------
    Dim cuenta As Integer
    cuenta = i
    i = i + 2
    
    wvarSuma = 0
    
    For j = 2 To cuenta
        If .TableCell(tcText, j, 5) = "" Then
            wvarSuma = Val(CDbl(wvarSuma)) + 0
        Else
            wvarSuma = Val(CDbl(wvarSuma)) + Val(CDbl(.TableCell(tcText, j, 5)))
        End If
    Next j
    
    wvarTotProd = wvarTotProd + wvarSuma
    
    .TableCell(tcRows) = i
    .TableCell(tcAlign, i, 5) = taRightTop
    .TableCell(tcFontBold, i) = True
    .TableCell(tcBackColor, i, 3) = vbYellow: .TableCell(tcBackColor, i, 4) = vbYellow: .TableCell(tcBackColor, i, 5) = vbYellow
    .TableCell(tcText, i, 3) = "TOTAL PRODUCTOS"
    .TableCell(tcText, i, 5) = Format(Val(CDbl(wvarTotProd)), "##,##")
    Print #1, .TableCell(tcText, i, 1) & "|" & .TableCell(tcText, i, 2) & "|" & .TableCell(tcText, i, 3) & _
                "|" & .TableCell(tcText, i, 4) & "|" & .TableCell(tcText, i, 5) & "|"
                
'---Costo-Presentacion---------------------------------------------------------------------------------------
    
'    strSQL = "SELECT * From b_ssll_pctcosto With(NoLock) WHERE pcs_codcen = '" & cencos & "' " & _
'             "AND pcs_desde <= " & wvarTotProd & " AND pcs_hasta >= " & wvarTotProd
'    Set RS6 = vg_db.Execute(strSQL)

'    If Not RS6.EOF Then
'        Do While Not RS6.EOF
'            wvarPorcentajeCostoServ = Trim(RS6!pcs_pctcos)
'            RS6.MoveNext
'        Loop
'    Else
'        wvarPorcentajeCostoServ = 0
'    End If
'    RS6.Close: Set RS6 = Nothing

    strSQL = "SELECT * From b_ssll_porctoser With(NoLock) WHERE pcs_codcen = '" & cencos & "' " & _
             "AND pcs_period = '" & periodo & "'"
    Set RS6 = vg_db.Execute(strSQL)

    If Not RS6.EOF Then
        Do While Not RS6.EOF
            wvarPorcentajeCostoServ = IIf(IsNull(RS6!pcs_porcen), 0, RS6!pcs_porcen)
            RS6.MoveNext
        Loop
    Else
        wvarPorcentajeCostoServ = 0
    End If
    RS6.Close: Set RS6 = Nothing

    i = i + 1
    .TableCell(tcRows) = i
    .TableCell(tcAlign, i, 5) = taRightTop
    .TableCell(tcFontBold, i) = True
    .TableCell(tcBackColor, i, 3) = vbYellow: .TableCell(tcBackColor, i, 4) = vbYellow: .TableCell(tcBackColor, i, 5) = vbYellow
    
    .TableCell(tcText, i, 3) = "COSTO SERVICIO " & wvarPorcentajeCostoServ & "%"
    
    If (wvarPorcentajeCostoServ = 0) Then
        wvarCostoServ = 0
        .TableCell(tcText, i, 5) = Val(CDbl(wvarCostoServ))
    Else
        wvarCostoServ = Redondear(Val(CDbl(wvarTotProd * (wvarPorcentajeCostoServ / 100))), 0)
        .TableCell(tcText, i, 5) = Format(Val(CDbl(wvarCostoServ)), "##,##")
    End If
    
    Print #1, .TableCell(tcText, i, 1) & "|" & .TableCell(tcText, i, 2) & "|" & .TableCell(tcText, i, 3) & _
                "|" & .TableCell(tcText, i, 4) & "|" & .TableCell(tcText, i, 5) & "|"
                
'---Neto-----------------------------------------------------------------------------------------------------
    i = i + 2
    .TableCell(tcRows) = i
    .TableCell(tcBackColor, i, 4) = vbYellow: .TableCell(tcBackColor, i, 5) = vbYellow
    .TableCell(tcFontBold, i) = True
    .TableCell(tcAlign, i, 5) = taRightTop
    
    wvarNeto = Val(CDbl(wvarTotProd)) + Val(CDbl(wvarCostoServ))
    .TableCell(tcText, i, 4) = "NETO"
    .TableCell(tcText, i, 5) = Format(Val(wvarNeto), "##,##")
    
    Print #1, .TableCell(tcText, i, 1) & "|" & .TableCell(tcText, i, 2) & "|" & .TableCell(tcText, i, 3) & _
                "|" & .TableCell(tcText, i, 4) & "|" & .TableCell(tcText, i, 5) & "|"
                
'---IVA------------------------------------------------------------------------------------------------------
    i = i + 1
    .TableCell(tcRows) = i
    .TableCell(tcBackColor, i, 4) = vbYellow: .TableCell(tcBackColor, i, 5) = vbYellow
    .TableCell(tcFontBold, i) = True
    .TableCell(tcAlign, i, 5) = taRightTop
    
    .TableCell(tcText, i, 4) = "IVA"
    strSQL = "SELECT imp_pctimp FROM a_impuesto WHERE imp_codigo = '1'"
    Set RS1 = vg_db.Execute(strSQL)
    
    If Not RS1.EOF Then
        Do While Not RS1.EOF
             wvarIVA = RS1!imp_pctimp
             RS1.MoveNext
        Loop
    End If
    RS1.Close: Set RS1 = Nothing
    
    wvarValorIVA = Redondear((Val(CDbl(wvarNeto)) * Val(CDbl(wvarIVA))) / 100, 0)
    .TableCell(tcText, i, 5) = Format(wvarValorIVA, "##,##")
    
    Print #1, .TableCell(tcText, i, 1) & "|" & .TableCell(tcText, i, 2) & "|" & .TableCell(tcText, i, 3) & _
                "|" & .TableCell(tcText, i, 4) & "|" & .TableCell(tcText, i, 5) & "|"
            
'---Total----------------------------------------------------------------------------------------------------
    
    wvarTotalNV = Format(Val(wvarNeto) + Val(wvarValorIVA), "##,##")
    
    i = i + 1
    .TableCell(tcRows) = i
    .TableCell(tcBackColor, i, 4) = vbYellow: .TableCell(tcBackColor, i, 5) = vbYellow
    .TableCell(tcFontBold, i) = True
    .TableCell(tcAlign, i, 5) = taRightTop
    .TableCell(tcText, i, 4) = "TOTAL"
    .TableCell(tcText, i, 5) = wvarTotalNV
    
    Print #1, .TableCell(tcText, i, 1) & "|" & .TableCell(tcText, i, 2) & "|" & .TableCell(tcText, i, 3) & _
        "|" & .TableCell(tcText, i, 4) & "|" & .TableCell(tcText, i, 5) & "|"
                
'------------------------------------------------------------------------------------------------------------

    .TableCell(tcRows) = i
    .PenColor = &HC0C0C0
    .TableBorder = tbAll
    .EndTable
    .EndDoc
    Close #1
End With
Preview.Show 1
fg_descarga
Exit Function
Error_DsctoxVol:
    fg_descarga
    MsgBox Err.Number & " " & Err.Description, vbExclamation + vbOKOnly, MsgTitulo
    Close #1
    Exit Function
End Function

