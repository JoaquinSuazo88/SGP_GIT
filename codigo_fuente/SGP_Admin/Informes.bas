    For j = 2 To varCantCol
        .TableCell(tcText, 1, j) = "Monto"
        j = j + 1
        .TableCell(tcText, 1, j) = "%"
    Next j
    
    strPrint = ""
    For k = 1 To varCantCol
        strPrint = strPrint & .TableCell(tcText, 1, k) & "|"
    Next k
    Print #1, strPrint

    .TableBorder = tbBox
    .EndTable
    
'------------------------------------------------------------------------------------------------------------------------
    
    .StartTable
    .TableCell(tcCols) = varCantCol: .TableCell(tcRows) = 10000
    .TableCell(tcRowHeight, 0, 1) = 2000
    .TableCell(tcColWidth, , 1) = 3000: .TableCell(tcAlign, , 1) = taLeftTop
    
    For k = 2 To varCantCol
        .TableCell(tcColWidth, , k) = 1000: .TableCell(tcAlign, , k) = taRightMiddle
    Next k
    
    i = 1
    wvarCantidad = 1
    wvarCol = 2
    Dim ArregloCompEvo() As String
    
    strSQL = "SELECT * FROM a_tipopro a WHERE a.tip_previo = 0 AND a.tip_activo = 1"
    Set RS2 = vg_db.Execute(strSQL)
    
    strSQL = "ssll_s_comprasevolucion '" & cencos & "'"
    RS4.CursorLocation = adUseClient
    RS4.Open strSQL, vg_db, adOpenForwardOnly, adLockReadOnly
    Set RS1 = RS4.Clone(adLockReadOnly)
    
    
    Do While Not RS2.EOF
        strSQL = "SELECT * FROM a_tipopro WITH (HOLDLOCK) WHERE tip_previo = " & RS2!tip_codigo & " ORDER BY tip_nombre"
        Set RS3 = vg_db.Execute(strSQL)
        
        .TableCell(tcText, i, 1) = Trim(RS2!tip_nombre)
        .TableCell(tcBackColor, i) = &HC0C0FF
        i = i + 1
        
        Do While Not RS3.EOF
            varStrFamilia = Trim(RS2!tip_nombre & "\" & RS3!tip_nombre)
            
            If RS3!tip_previo <> 0 Then
                
            strSQL = "SELECT CONVERT(varchar(6),ocr_fecoc,112) AS ocr_fecoc FROM cas_b_ocsacrecibido WITH (HOLDLOCK) " & _
                     "WHERE ocr_cecori = '" & cencos & "' AND ocr_fecoc IS NOT NULL " & _
                     "GROUP BY CONVERT(varchar(6),ocr_fecoc,112) ORDER BY ocr_fecoc DESC"
            Set RSPer = vg_db.Execute(strSQL)
                
                wvarCol = 2
                
                Do While Not RSPer.EOF
                    Do While Not RS1.EOF
                        If i = 2 Then
                            wvarfecha = Trim(RS1!fecrem)
                        End If
                        
                        ArregloCompEvo = Split(Trim(RS1!fampro), "\")
                        wvarCortarArreglo = ArregloCompEvo(1)
                        
                        If (Trim(RS3!tip_nombre) = Trim(wvarCortarArreglo)) Then
                            
                            If (RSPer!ocr_fecoc = RS1!fecrem) Then
                                .TableCell(tcText, i, wvarCol) = Format(Val(RS1!totpro), fg_Pict(9, 2))
                            End If
                        End If
    
                        RS1.MoveNext
                    Loop
                    RS1.MoveFirst
                    wvarCol = wvarCol + 2
                RSPer.MoveNext
            Loop
                
                wvarCol = 2
                SumaFamilia = 0
                .TableCell(tcText, i, 1) = Trim(RS3!tip_nombre)
            End If
            i = i + 1
            RS3.MoveNext
        Loop
        i = i + 1
        RS2.MoveNext
    Loop
    
    RS1.Close: Set RS1 = Nothing
    RS2.Close: Set RS2 = Nothing
    RS3.Close: Set RS3 = Nothing
    RS4.Close: Set RS4 = Nothing
    RSPer.Close: Set RSPer = Nothing
    
    For k = 1 To i
        If (.TableCell(tcBackColor, k, 1) <> &HC0C0FF) Then
            If Trim(.TableCell(tcText, k, 1)) <> "" Then
                For q = 2 To varCantCol
                    If .TableCell(tcText, k, q) = "" Then
                        .TableCell(tcText, k, q) = 0
                    End If
                    
                    q = q + 1
                Next q
            End If
        End If
    Next k
    
    Dim wvarTotalMes As Double
    wvarTotalMes = 0
    
