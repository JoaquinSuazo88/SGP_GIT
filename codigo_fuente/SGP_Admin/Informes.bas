               .TableCell(tcText, 2, 1) = ""
               .TableBorder = tbNone
               .EndTable
               .text = Chr(13): .text = Chr(13)
               .StartTable
               .TableCell(tcCols) = 4: .TableCell(tcRows) = 4
               .TableCell(tcColWidth, , 1) = 1500: .TableCell(tcAlign, , 1) = taLeftTop
               .TableCell(tcColWidth, , 2) = 3300: .TableCell(tcAlign, , 1) = taLeftTop
               .TableCell(tcColWidth, , 3) = 1500: .TableCell(tcAlign, , 1) = taLeftTop
               .TableCell(tcColWidth, , 4) = 4200: .TableCell(tcAlign, , 1) = taLeftTop
               .TableCell(tcFontBold, , 1) = True: .TableCell(tcFontBold, , 3) = True
               .TableCell(tcText, 1, 1) = "Sub-Segmento"
               .TableCell(tcText, 1, 2) = codsub & " - " & nomsub
               .TableCell(tcText, 1, 3) = "Regimen"
               .TableCell(tcText, 1, 4) = codReg & " - " & nomreg
               .TableCell(tcText, 2, 1) = "Servicios"
               .TableCell(tcText, 2, 2) = Trim(auxser) & " - " & Trim(auxnom)
               .TableCell(tcText, 3, 1) = "Zona"
               .TableCell(tcText, 3, 2) = codzon & " - " & nomzon
               .TableCell(tcText, 3, 3) = "Lista Precio"
               .TableCell(tcText, 3, 4) = codlpr & " - " & nomlpr
                    
               .TableBorder = tbBoxRows
               .TableBorder = tbNone
               .EndTable
               .FontSize = 7
               .text = Chr(13): .text = Chr(13)
               
               .StartTable
               .TableCell(tcCols) = 2: .TableCell(tcRows) = 1000
               .TableCell(tcColWidth, , 1) = 4500: .TableCell(tcAlign, , 1) = taLeftTop
               .TableCell(tcColWidth, , 2) = 2000: .TableCell(tcAlign, , 2) = taRightTop
               i = 1
               totmes = 0
                For X = 1 To UBound(VecResDia)
                    .TableCell(tcFontBold, i, 1) = True: .TableCell(tcText, i, 1) = "Costo Total día x Estructura " & Mid(VecResDia(X, 1), 7, 2) & "/" & Mid(VecResDia(X, 1), 5, 2) & "/" & Mid(VecResDia(X, 1), 1, 4)
                    .TableCell(tcFontBold, i, 2) = True: .TableCell(tcText, i, 2) = Format(VecResDia(X, 2), fg_Pict(9, vg_DPr))
                    i = i + 1: totmes = totmes + VecResDia(X, 2)
                Next X
                i = i + 2
                .TableCell(tcFontBold, i, 1) = True: .TableCell(tcText, i, 1) = "Costo Promedio x Estructura "
                .TableCell(tcFontBold, i, 2) = True: .TableCell(tcText, i, 2) = Format(totmes / UBound(VecResDia), fg_Pict(9, vg_DPr))
               
               .TableCell(tcRows) = i
               .PenColor = &HC0C0C0
               .TableBorder = tbNone '= tbBottom
               .EndTable
               .NewPage
            End If
          End If
          estpag = True
          'TITULO INFORME
          .StartTable
          .TableCell(tcCols) = 1: .TableCell(tcRows) = 2
          .TableCell(tcColWidth, , 1) = 10500: .TableCell(tcAlign, , 1) = taCenterMiddle
          .TableCell(tcFontSize, 1) = 14: .TableCell(tcFontBold, 1) = True
          .TableCell(tcFontSize, 2) = 8: .TableCell(tcFontBold, 2) = True: .TableCell(tcForeColor, 2) = &H4080&
          .TableCell(tcText, 1, 1) = "Costos Detalle Minuta " & " - " & IIf(Indppr = "1", "Real", "Propuesta")
          .TableCell(tcText, 2, 1) = ""
          .TableBorder = tbNone
          .EndTable
          .text = Chr(13): .text = Chr(13)
                    
          .StartTable
          .TableCell(tcCols) = 4: .TableCell(tcRows) = 4
          .TableCell(tcColWidth, , 1) = 1500: .TableCell(tcAlign, , 1) = taLeftTop
          .TableCell(tcColWidth, , 2) = 3300: .TableCell(tcAlign, , 1) = taLeftTop
          .TableCell(tcColWidth, , 3) = 1500: .TableCell(tcAlign, , 1) = taLeftTop
          .TableCell(tcColWidth, , 4) = 4200: .TableCell(tcAlign, , 1) = taLeftTop
          .TableCell(tcFontBold, , 1) = True: .TableCell(tcFontBold, , 3) = True
          .TableCell(tcText, 1, 1) = "Sub-Segmento"
          .TableCell(tcText, 1, 2) = codsub & " - " & nomsub
          .TableCell(tcText, 1, 3) = "Regimen"
          .TableCell(tcText, 1, 4) = codReg & " - " & nomreg
          .TableCell(tcText, 2, 1) = "Servicios"
          .TableCell(tcText, 2, 2) = Trim(RS1!Ser_codigo) & " - " & Trim(RS1!ser_nombre)
          
            If opSemCerrada = False Then
                .TableCell(tcText, 2, 3) = "Fecha Minuta"
                .TableCell(tcText, 2, 4) = fg_Ctod1(RS1!min_fecmin)
            Else
                .TableCell(tcText, 2, 3) = "Día"
                .TableCell(tcText, 2, 4) = " " & IniIncDia
                IniIncDia = IniIncDia + 1
            End If
             
'          .TableCell(tcText, 2, 3) = "Fecha Minuta"
'          .TableCell(tcText, 2, 4) = fg_Ctod1(RS1!min_fecmin)
          
          .TableCell(tcText, 3, 1) = "Zona"
          .TableCell(tcText, 3, 2) = codzon & " - " & nomzon
          .TableCell(tcText, 3, 3) = "Lista Precio"
          .TableCell(tcText, 3, 4) = codlpr & " - " & nomlpr
          .TableCell(tcText, 4, 1) = "Rac. Efectivas"
          .TableCell(tcText, 4, 2) = RS1!min_racteo
                
          .TableBorder = tbBoxRows
'                rutcli = Trim(cencos)
'                numdoc = RS1!tov_numdoc
          .TableBorder = tbNone
          .EndTable
          .FontSize = 7
                    
          .StartTable
          .TableCell(tcCols) = 6: .TableCell(tcRows) = 1
          .TableCell(tcColWidth, , 1) = 900: .TableCell(tcAlign, , 1) = taLeftTop
          .TableCell(tcColWidth, , 2) = 4500: .TableCell(tcAlign, , 2) = taLeftTop
          .TableCell(tcColWidth, , 3) = 600: .TableCell(tcAlign, , 3) = taCenterTop
          .TableCell(tcColWidth, , 4) = 1100: .TableCell(tcAlign, , 4) = taRightTop
          .TableCell(tcColWidth, , 5) = 1100: .TableCell(tcAlign, , 5) = taRightTop
          .TableCell(tcColWidth, , 6) = 1100: .TableCell(tcAlign, , 6) = taRightTop
          .TableCell(tcBackColor, 1) = vbYellow: .TableCell(tcFontBold, 1) = True: .TableCell(tcRowHeight, 1) = 230
          .TableCell(tcText, 1, 1) = "Código"
          .TableCell(tcText, 1, 2) = "Descripción Recetas"
          .TableCell(tcText, 1, 3) = ""
          .TableCell(tcText, 1, 4) = "Costo Unit."
          .TableCell(tcText, 1, 5) = "Nş Comen."
          .TableCell(tcText, 1, 6) = "Costo Bandeja"
          .TableBorder = tbBox
          .EndTable
                    
          .StartTable
          .TableCell(tcCols) = 6: .TableCell(tcRows) = 1000
          .TableCell(tcColWidth, , 1) = 900: .TableCell(tcAlign, , 1) = taLeftTop
          .TableCell(tcColWidth, , 2) = 4500: .TableCell(tcAlign, , 2) = taLeftTop
          .TableCell(tcColWidth, , 3) = 600: .TableCell(tcAlign, , 3) = taCenterTop
          .TableCell(tcColWidth, , 4) = 1100: .TableCell(tcAlign, , 4) = taRightTop
          .TableCell(tcColWidth, , 5) = 1100: .TableCell(tcAlign, , 5) = taRightTop
          .TableCell(tcColWidth, , 6) = 1100: .TableCell(tcAlign, , 6) = taRightTop
          If auxser <> RS1!Ser_codigo Then
             condia = 0
             'definir largo del vector
             Set RS2 = vg_db.Execute("SELECT  COUNT(distinct a.min_fecmin) AS nreg FROM b_minuta a, b_minutadet b WHERE a.min_codigo = b.mid_codigo AND a.min_subseg = " & codsub & " AND a.min_codreg = " & codReg & " AND a.min_codser = " & RS1!Ser_codigo & " AND a.min_fecmin >= " & FecIni & " AND a.min_fecmin <= " & FecFin & "")
             If Not RS1.EOF Then
                ReDim VecResDia(RS2!nReg, 2)
             End If
             RS2.Close: Set RS2 = Nothing
             
             'setear vector
             For X = 1 To UBound(VecResDia)
                VecResDia(X, 1) = "" 'fecha
                VecResDia(X, 2) = 0 'costo
             Next X
             IndDia = 1
          End If
          condia = condia + 1
          auxser = RS1!Ser_codigo
          auxnom = RS1!ser_nombre
          AuxFec = RS1!min_fecmin
          i = 1
       End If
       If auxess <> RS1!ess_codigo Then
