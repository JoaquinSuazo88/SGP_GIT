    .TableCell(tcCols) = 3 + I_Produc.List1.SelCount: .TableCell(tcRows) = 60000
    cLin = "": auxpro = ""
    fil = 1
    Do While Not RS1.EOF
       fil = fil + 1
       .TableCell(tcColWidth, , 1) = 1000: .TableCell(tcAlign, , 1) = taLeftTop
       .TableCell(tcColWidth, , 2) = 1000: .TableCell(tcAlign, , 2) = taLeftTop
       .TableCell(tcColWidth, , 3) = 500: .TableCell(tcAlign, , 3) = taLeftTop
       .TableCell(tcText, fil, 1) = RS1!pro_codigo
       .TableCell(tcText, fil, 2) = Trim(RS1!pro_nombre)
       .TableCell(tcText, fil, 3) = IIf(Trim(RS1!pro_indppr) = 1, "Real", "Prop.")
       cLin = cLin & .TableCell(tcText, fil, 1) & "|" & .TableCell(tcText, fil, 2)
       auxpro = RS1!pro_codigo
       If IsNull(RS1!tem_codigo) Then
          RS1.MoveNext
       Else
          Do While RS1!pro_codigo = auxpro And Not RS1.EOF
             .TableCell(tcText, fil, VecCol(Val(RS1!tem_codigo))) = Format(RS1!tem_nombre, fg_Pict(6, 2))
             RS1.MoveNext
             If RS1.EOF Then Exit Do
          Loop
       End If
       For i = 3 To Col - 1
           cLin = cLin & "|" & .TableCell(tcText, fil, i)
       Next
       Print #1, cLin
       cLin = ""
    Loop
    RS1.Close: Set RS1 = Nothing: Close #1
    .TableCell(tcColWidth, 1, 4, fil, Col) = 700: .TableCell(tcAlign, 1, 3, fil, Col) = taCenterTop
    .TableCell(tcRows) = fil
    .PenColor = &HC0C0C0
    .TableBorder = tbAll
    .EndTable
    .EndDoc
