Attribute VB_Name = "M_Produ1"
Attribute VB_GlobalNameSpace = False
Attribute VB_Creatable = False
Attribute VB_PredeclaredId = True
Attribute VB_Exposed = False
Dim RS As New ADODB.Recordset
Dim RS1 As New ADODB.Recordset
Private Sub Form_Load()
RS.Open "select ing_codigo, ing_nombre from b_ingrediente order by ing_codigo", vg_db, adOpenStatic
TvwDir.Nodes.Clear
If Not RS.EOF Then
   Do While Not RS.EOF
      Set rootnode = TvwDir.Nodes.Add(, , "R" & RS!ing_codigo, Trim(RS!ing_nombre))
      ' agregar un nodo hijo postizo, si fuera necesario
'      rootnode.ExpandedImage = 4
      If rootnode.Children = 0 Then
         RS1.Open "select distinct pri_codpro from b_productosing where pri_coding='" & RS!ing_codigo & "'", vg_db, adOpenStatic
           If Not RS1.EOF Then
              ' la propiedad Texto de los nodos postizos es "***"
              TvwDir.Nodes.Add rootnode.Index, tvwChild, , "*"
           End If
           RS1.Close: Set RS1 = Nothing
        End If
        RS.MoveNext
    Loop
End If
RS.Close: Set RS = Nothing
End Sub

Private Sub tvwDir_Expand(ByVal Node As MSComctlLib.Node)
Set dest = Node
If Node.Children = 0 Or Node.Children > 1 Then Exit Sub
If Node.Child.Text <> "*" And Node.Child.Text <> "**" Then Exit Sub
' eliminar el elemento hijo positivo
TvwDir.Nodes.Remove Node.Child.Index
RS1.Open "select b_productos.pro_codigo, b_productos.pro_nombre from  b_productos, b_productosing " & _
         "where  b_productos.pro_codigo=b_productosing.pri_codpro " & _
         "and    b_productosing.pri_coding='" & Val(Mid(TvwDir.Nodes(dest.Index).Key, 2, 20)) & "' " & _
         "order by b_productos.pro_codigo", vg_db, adLockReadOnly
If Not RS1.EOF Then
   Do While Not RS1.EOF
      Set nd = TvwDir.Nodes.Add(dest.Index, tvwChild, "H" & RS1!pro_codigo, Trim(RS1!pro_nombre))
'      dest.ExpandedImage = 4
 '     If nd.Children = 0 Then
 '        RS2.Open "select distinct " & Suf & "previo " & "from " & Tabla & " where " & Suf & "previo=" & RS1(0) & "", vg_db, adOpenStatic
 '        If Not RS2.EOF Then
 '           ' la propiedad Texto de los nodos positivos es "***"
 '           TvwDir.Nodes.Add nd.Index, tvwChild, , "**"
 '         End If
 '         RS2.Close: Set RS2 = Nothing
 '     End If
      RS1.MoveNext
   Loop
End If
RS1.Close: Set RS1 = Nothing
End Sub
